1e6e5941abc2"],

Cell[CellGroupData[{

Cell["Fitting model parameters to data: A least squares approach", \
"Subsection",
 CellChangeTimes->{{3.8720010610340633`*^9, 3.872001100129839*^9}, {
   3.9329377073927393`*^9, 3.932937707727983*^9}, {3.933683321448051*^9, 
   3.9336833332368727`*^9}, 3.933692571165206*^9, {3.933711009724065*^9, 
   3.933711009784306*^9}},ExpressionUUID->"fd6a45c5-0612-4f7e-98d3-\
5df74140fb78"],

Cell[TextData[{
 StyleBox["The deliverables associated with this portion of the project are:",
  
  FontWeight->"Bold"],
 "\n1) The following plot with 10 tiles\n2) Plots must include ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c9ee1d5f-4a5c-41da-8b52-c9c639352752"],
 " values (as in the plots below)\n3) State whether the ratio of the number \
of rows to columns is greater-than, less-than, or equal to 1 in each case\n4) \
Numeric proof that ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["W", "\[LeftRightVector]"], TraditionalForm]],ExpressionUUID->
  "59d5193a-8e86-48a2-9006-996dc3ba06a1"],
 " is Hermitian"
}], "Text",
 CellChangeTimes->{{3.933692488028099*^9, 3.933692490750808*^9}, {
  3.933692620923024*^9, 3.9336926370583763`*^9}, {3.93369602632321*^9, 
