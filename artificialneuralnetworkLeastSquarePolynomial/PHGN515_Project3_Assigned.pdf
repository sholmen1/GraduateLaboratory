bIEVpZ6HMCLKxRKYTfPUk/5O71Rpxx1ElqLpAnqtVfl0Eo84cqcpS41+kKF7
C4B9XfxI2Hs3xIauuQs9WmLmk87paUK/giZSTFUPvD6xvuhyyB+p1Q73ZarC
LaJpc7ASfqu/NEm5NG/WatDCRLsjTkOk1EYO/BwoTYatw/+2scSp0Fj+wYe3
2oM8aDHHl8A/rTT3tA==
  "],ExpressionUUID->"4f52a210-af18-484c-a04c-3fd8419739a8"],

Cell[CellGroupData[{

Cell["Least squares math", "Subsubsection",
 CellChangeTimes->{{3.932992851876466*^9, 
  3.932992858140954*^9}},ExpressionUUID->"9423c98d-b242-40bd-a2b1-\
3db40870a7f9"],

Cell[TextData[{
 "In a linear regression model the model function is comprised of a linear \
superposition of parameters and basis functions e.g.,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{"x", ",", "\[Beta]"}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "k"], 
     SubscriptBox["\[Beta]", "k"], 
     RowBox[{
      SubscriptBox["\[Phi]", "k"], "(", "x", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"01032cdb-1a65-4c9d-b8dc-83455fc28c3c"],
 "\n\nwhere here, the index \[OpenCurlyQuote]",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "65264c2a-b95b-4361-9afe-a3f5ae1544bf"],
 "\[CloseCurlyQuote] indicates the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "90c2b4c8-982f-46e5-a369-26307e44f30b"],
 " coefficient for the corresponding, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "726844eb-98cc-4e36-a125-00d18b5d3037"],
 " basis function. We now write this in matrix form as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["f", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
     OverscriptBox["\[Beta]", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"20768bf9-b5e0-4c3f-8e0b-60699464a166"],
 "\n\nwhere, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPhi]", 
    RowBox[{"i", ",", " ", "j"}]], TraditionalForm]],ExpressionUUID->
  "a770f1be-71c9-4ccd-af79-fd476d877a93"],
 " are the matrix elements of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], TraditionalForm]],
  ExpressionUUID->"8b2667a2-397e-42ee-8c2a-39e579a23c41"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "j"], TraditionalForm]],ExpressionUUID->
  "2e0c601c-ce23-4be7-920a-537d64f82a1e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "i"], TraditionalForm]],ExpressionUUID->
  "c7d46be1-ea6b-4e94-a372-d78e394a63b7"],
 " are the ",
 StyleBox["column vector",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " elements of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Beta]", "\[RightVector]"], TraditionalForm]],
  ExpressionUUID->"eb5391a1-6c5b-4e11-985a-bf13961ad948"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["f", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "d56e601e-8990-4c53-a2a5-0474982ed1cb"],
 " respectively. That is to say, in index notation\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "i"], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["\[CapitalPhi]", 
      RowBox[{"i", ",", " ", "j"}]], 
     SubscriptBox["\[Beta]", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "b5d4ae38-aa88-473c-9b1a-26dab4ba2ebe"],
 "\n\nwe define the residuals as the difference between the model, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["f", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "3d926177-ae22-4e6f-a5ae-71b91564b2d3"],
 " and the data, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["y", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "a6ec6c48-1c6a-490f-97d6-4226a7f95c30"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["r", "\[RightVector]"], "\[Congruent]", 
    RowBox[{
     OverscriptBox["y", "\[RightVector]"], "-", 
     RowBox[{
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"d941bd74-3401-44b6-81a3-f997aa3b9a32"],
 "\n\nNow, we write the cost function as the sum of the absolute valued \
squared residuals (all variables are real here).\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", "(", 
      RowBox[{
       OverscriptBox["y", "\[RightVector]"], ",", "\[Beta]"}], ")"}], 
     "\[Congruent]", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], 
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["r", "j"], "\[RightBracketingBar]"}], "2"]}]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{
         SubscriptBox["y", "j"], "-", 
         RowBox[{
          SubscriptBox["\[CapitalPhi]", 
           RowBox[{"i", ",", " ", "j"}]], 
          SubscriptBox["\[Beta]", "j"]}]}], "\[RightBracketingBar]"}], "2"], 
      " ", 
      OverscriptBox["\[LongRightArrow]", "real"], "  ", 
      SuperscriptBox[
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "j"], " ", "[", 
        RowBox[{
         SubscriptBox["y", "j"], "-", 
         RowBox[{
          SubscriptBox["\[CapitalPhi]", 
           RowBox[{"i", ",", " ", "j"}]], 
          SubscriptBox["\[Beta]", "j"]}]}], "]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"337f14ee-269a-4467-8915-fc6d03eee433"],
 "\n\nthis can be conveniently expressed in matrix notation as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", "(", 
      RowBox[{
       OverscriptBox["y", "\[RightVector]"], ",", "\[Beta]"}], ")"}], 
     "\[Congruent]", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["y", "\[RightVector]"], "-", 
         RowBox[{
          OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
          OverscriptBox["\[Beta]", "\[RightVector]"]}]}], ")"}], "T"], 
      RowBox[{"(", 
       RowBox[{
        OverscriptBox["y", "\[RightVector]"], "-", 
        RowBox[{
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
         OverscriptBox["\[Beta]", "\[RightVector]"]}]}], ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], "-", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["\[Beta]", "\[RightVector]"], "T"], 
        SuperscriptBox[
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"]}]}], 
      ")"}], 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["y", "\[RightVector]"], "-", 
       RowBox[{
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"578d5234-07e7-47bd-a16b-530405fc8bcc"],
 "\n\nThe goal here will be to minimize the residuals. That is to say, we \
will calculate the derivative of the cost function w.r.t. to the model \
parameters, then set the resulting gradient to zero, and solve for the model \
parameters that minimize the cost function. Again, the measured points are in \
",
 Cell[BoxData[
  FormBox[
   OverscriptBox["y", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "987cd658-ec6b-4a93-b880-4b211ec3f337"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["f", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
     OverscriptBox["\[Beta]", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"9a13539f-08f4-477b-8ae2-4b09008ca95e"],
 "  is our model. Multiplying this out, we get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", 
     RowBox[{
      OverscriptBox["y", "\[RightVector]"], ",", "\[Beta]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["y", "\[RightVector]"], "T"], 
      OverscriptBox["y", "\[RightVector]"]}], "-", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["y", "\[RightVector]"], "T"], "(", 
      RowBox[{
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
       OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "-", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
         OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "T"], 
      OverscriptBox["y", "\[RightVector]"]}], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
         OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "T"], 
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"ed0dfd40-5f35-4ede-8bbc-bad9e6ef238d"],
 "\n\nwe write the two central terms as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", 
     RowBox[{
      OverscriptBox["y", "\[RightVector]"], ",", "\[Beta]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["y", "\[RightVector]"], "T"], 
      OverscriptBox["y", "\[RightVector]"]}], "+", 
     RowBox[{"\[LeftDoubleBracket]", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{
         SuperscriptBox[
          OverscriptBox["y", "\[RightVector]"], "T"], "(", 
         RowBox[{
          OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
          OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}]}], "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           OverscriptBox["y", "\[RightVector]"], "T"], "(", 
          RowBox[{
           OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
           OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], ")"}], "T"]}],
       "\[RightDoubleBracket]"}], "+", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"], 
      OverscriptBox["v", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"9c6a1e19-d0e2-44ad-9a08-ca34f3500efe"],
 "\n\nwhere we\[CloseCurlyQuote]ve also defined ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["v", "\[RightVector]"], "=", 
    RowBox[{
     RowBox[{
      OverscriptBox["v", "\[RightVector]"], "(", 
      OverscriptBox["\[Beta]", "\[RightVector]"], ")"}], "\[Congruent]", 
     RowBox[{
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"1de83309-7eb8-458f-bdf7-64c6250a006d"],
 " for simplicity in the following arguments. Each term is a scalar, which \
means the central two terms are equal\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["y", "\[RightVector]"], "T"], "(", 
     RowBox[{
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
      OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], "(", 
       RowBox[{
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
        OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], ")"}], "T"]}], 
   TraditionalForm]],ExpressionUUID->"b546229f-d2a8-4bd5-b0b8-93b11447df36"],
 "\n\nbecause ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Alpha]", "T"], "=", "\[Alpha]"}], TraditionalForm]],
  ExpressionUUID->"d8771cf5-8442-4336-8196-bd2339d1b264"],
 ", when \[Alpha] is a scalar\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["y", "\[RightVector]"], "T"], 
      OverscriptBox["y", "\[RightVector]"]}], "-", 
     RowBox[{"2", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], "(", 
       RowBox[{
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
        OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"], 
      OverscriptBox["v", "\[RightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"d7bdedf9-c0bc-4299-af6e-6cd398e68592"],
 "\n\nnow taking the vector derivative of the cost function w.r.t. ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Beta]", "\[RightVector]"], TraditionalForm]],
  ExpressionUUID->"76cd6edf-a3dc-411e-bf33-aad940ee4eb8"],
 ", we will use the ",
 ButtonBox["numerator layout",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Matrix_calculus#Scalar-by-vector_\
identities"], None},
  ButtonNote->
   "https://en.wikipedia.org/wiki/Matrix_calculus#Scalar-by-vector_\
identities"],
 " convention for vector derivatives of scalar functions:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], 
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], "+", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          OverscriptBox["v", "\[RightVector]"], "T"], 
         RowBox[{
          FractionBox["\[PartialD]", 
           RowBox[{"\[PartialD]", 
            OverscriptBox["\[Beta]", "\[RightVector]"]}]], 
          OverscriptBox["v", "\[RightVector]"]}]}], "+", 
        RowBox[{
         SuperscriptBox[
          OverscriptBox["v", "\[RightVector]"], "T"], 
         RowBox[{
          FractionBox["\[PartialD]", 
           RowBox[{"\[PartialD]", 
            OverscriptBox["\[Beta]", "\[RightVector]"]}]], 
          OverscriptBox["v", "\[RightVector]"]}]}]}], "]"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], 
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], "+", 
      RowBox[{"2", 
       SuperscriptBox[
        OverscriptBox["v", "\[RightVector]"], "T"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["v", "\[RightVector]"]}], 
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Beta]", "\[RightVector]"]}]]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"2b055be6-8259-45f9-ac82-23321b2bb437"],
 "\n\nnote that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]], 
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"]}], 
     OverscriptBox["v", "\[RightVector]"]}], "=", 
    RowBox[{"2", 
     SuperscriptBox[
      OverscriptBox["v", "\[RightVector]"], "T"], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       OverscriptBox["v", "\[RightVector]"]}], 
      RowBox[{"\[PartialD]", 
       OverscriptBox["\[Beta]", "\[RightVector]"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"0f959bfe-5705-4f5e-882f-e09b742a01c8"],
 "\n\ncomes from writing this in index notation where we define two new \
vector valued functions: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["u", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["u", "\[RightVector]"], "(", 
     OverscriptBox["\[Beta]", "\[RightVector]"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"93cd561f-d606-4b94-a6ea-e48e5b0cb255"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["v", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["v", "\[RightVector]"], "(", 
     OverscriptBox["\[Beta]", "\[RightVector]"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"2ae20f20-3cb9-4475-affe-391314ba78b8"],
 ", and we define the scalar ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Alpha]", "\[Congruent]", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["u", "\[RightVector]"], "T"], 
      OverscriptBox["v", "\[RightVector]"]}]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubscriptBox["u", "i"], 
     SubscriptBox["v", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "7a5e7b3f-4965-4b06-b86a-f56caf4168b7"],
 " as the inner product of the two vectors, then taking the derivative of \
\[Alpha]  w.r.t. the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "75a9362b-8306-4cc3-b014-ac3317ffdebc"],
 " component of \[Beta], we get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[Alpha]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "k"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         SubscriptBox["\[Beta]", "k"]}]], 
       SubscriptBox["\[CapitalSigma]", "i"]}], 
      SubscriptBox["u", "i"], 
      SubscriptBox["v", "i"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "i"], 
       SubscriptBox["u", "i"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubscriptBox["v", "i"]}], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["\[Beta]", "k"]}]]}], "+", 
      RowBox[{
       SubscriptBox["v", "i"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubscriptBox["u", "i"]}], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["\[Beta]", "k"]}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"d774abfa-ecab-4e22-8a77-bd8ca4ebe377"],
 "\n\nnote that, in our convention (",
 ButtonBox["numerator layout",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Matrix_calculus#Scalar-by-vector_\
identities"], None},
  ButtonNote->
   "https://en.wikipedia.org/wiki/Matrix_calculus#Scalar-by-vector_\
identities"],
 "), ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", 
     SubscriptBox["v", "i"]}], 
    RowBox[{"\[PartialD]", 
     SubscriptBox["\[Beta]", "k"]}]], TraditionalForm]],ExpressionUUID->
  "35556bd1-3e3b-49a4-9912-76ab261d3421"],
 " and ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", 
     SubscriptBox["u", "i"]}], 
    RowBox[{"\[PartialD]", 
     SubscriptBox["\[Beta]", "k"]}]], TraditionalForm]],ExpressionUUID->
  "e29424a7-612e-406a-9535-e7234327cbbc"],
 " are matrix elements defined as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", 
     RowBox[{"i", ",", "k"}]], "\[Congruent]", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["v", "i"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "k"]}]]}], TraditionalForm]],ExpressionUUID->
  "95fb474f-ef68-495c-821b-3e805dcf2be4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["B", 
     RowBox[{"i", ",", "k"}]], "\[Congruent]", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["u", "i"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "k"]}]]}], TraditionalForm]],ExpressionUUID->
  "f665d5b1-0b13-4eba-8fb4-e9440d4df905"],
 " where both A and B have the same number of rows as the number of elements \
in v and u, respectively. If we insert these\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[Alpha]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "k"]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubscriptBox["u", "i"], 
      SubscriptBox["A", 
       RowBox[{"i", ",", "k"}]]}], "+", 
     RowBox[{
      SubscriptBox["v", "i"], 
      SubscriptBox["B", 
       RowBox[{"i", ",", "k"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "feb6018f-14eb-4494-a140-8a17f999743d"],
 "\n\nthen things are a little more clear and we can write this in vector \
form again. That is to say, we are multiplying elements of u and v by the \
rows of A and B,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[Alpha]"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["u", "\[RightVector]"], "T"], 
      OverscriptBox["A", "\[LeftRightVector]"]}], "+", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"], 
      OverscriptBox["B", "\[LeftRightVector]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"4a20fe29-4dce-464d-89c3-f12856522549"],
 "\n\nor, inserting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["A", "\[LeftRightVector]"], "=", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      OverscriptBox["v", "\[RightVector]"]}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]]}], TraditionalForm]],
  ExpressionUUID->"ac938544-3ec1-4d1e-b515-485e8eb5a2f6"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["B", "\[LeftRightVector]"], "=", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      OverscriptBox["u", "\[RightVector]"]}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]]}], TraditionalForm]],
  ExpressionUUID->"6e40f14f-c056-48c7-9fb9-ed5195f65c1f"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[Alpha]"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["u", "\[RightVector]"], "T"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        OverscriptBox["v", "\[RightVector]"]}], 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]]}], "+", 
     RowBox[{
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        OverscriptBox["u", "\[RightVector]"]}], 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"329853f5-d100-432a-a944-b7901ad8d122"],
 "\n\nin the special case where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["u", "\[RightVector]"], "=", 
    OverscriptBox["v", "\[RightVector]"]}], TraditionalForm]],ExpressionUUID->
  "225f738f-8e5c-4c6c-8e8e-af297f7249fb"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]], 
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"]}], 
     OverscriptBox["v", "\[RightVector]"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox[
        OverscriptBox["v", "\[RightVector]"], "T"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["v", "\[RightVector]"]}], 
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Beta]", "\[RightVector]"]}]]}], "+", 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["v", "\[RightVector]"], "T"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["v", "\[RightVector]"]}], 
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Beta]", "\[RightVector]"]}]]}]}], "=", 
     RowBox[{"2", 
      SuperscriptBox[
       OverscriptBox["v", "\[RightVector]"], "T"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        OverscriptBox["v", "\[RightVector]"]}], 
       RowBox[{"\[PartialD]", 
        OverscriptBox["\[Beta]", "\[RightVector]"]}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"1eab6435-16d1-4d9a-bea6-7fafcc16b39c"],
 "\n\nback to the original expression\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], 
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], "+", 
      RowBox[{"2", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
          OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], 
       SuperscriptBox[
        OverscriptBox["y", "\[RightVector]"], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], "+", 
      RowBox[{"2", 
       SuperscriptBox[
        OverscriptBox["\[Beta]", "\[RightVector]"], "T"], 
       SuperscriptBox[
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], 
       OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"6b6df075-eba3-4c1c-b695-260992d2c784"],
 "\n\nsetting this to zero and solving for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Beta]", "\[RightVector]"], TraditionalForm]],
  ExpressionUUID->"d787cf17-cbe0-4795-93e4-0edd5236e453"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["y", "\[RightVector]"], "T"], 
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["\[Beta]", "\[RightVector]"], "T"], 
     SuperscriptBox[
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], 
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}]}], 
   TraditionalForm]],ExpressionUUID->"a59fb878-7921-488d-a36b-a24b8cfac27d"],
 "\n\nor, taking the transpose of both sides\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], 
     OverscriptBox["y", "\[RightVector]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], " ", 
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], 
     OverscriptBox["\[Beta]", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"0fb1153b-a6b6-4dad-a06f-dcc8e154b567"],
 "\n\nwe get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Beta]", "\[RightVector]"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], " ", 
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], ")"}], 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], 
     OverscriptBox["y", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"e14defb2-274d-43a3-ac7d-1fa74dfb062c"],
 "\n\nThis shows that minimizing the absolute valued square of the residuals \
(so called \[OpenCurlyQuote]least squares\[CloseCurlyQuote]) gives a solution \
in the form of a ",
 ButtonBox["Moore-Penrose inverse",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Moore%E2%80%93Penrose_inverse"], None},
  
  ButtonNote->"https://en.wikipedia.org/wiki/Moore%E2%80%93Penrose_inverse"],
 " also called the pseudo-inverse and denoted ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "+"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"], 
        OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"]}], ")"}], 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "T"]}]}], 
   TraditionalForm]],ExpressionUUID->"f54af4ab-790a-48b5-994d-a8f616c89fa3"],
 ". Many software packages do not calculate this inverse directly as above. \
They compute the singular value decomposition of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], TraditionalForm]],
  ExpressionUUID->"c4764318-6183-435a-837e-064ea4f55046"],
 ", which is then inverted. That is to say, any (real in this case) matrix \
can be expressed in the following way\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "=", 
    RowBox[{
     OverscriptBox["U", "\[LeftRightVector]"], " ", 
     OverscriptBox["\[CapitalSigma]", "\[LeftRightVector]"], " ", 
     SuperscriptBox[
      OverscriptBox["V", "\[LeftRightVector]"], "T"]}]}], TraditionalForm]],
  ExpressionUUID->"7667dbd7-95bf-4607-8067-7802ab151e97"],
 "\n\nhere, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalSigma]", "\[LeftRightVector]"], TraditionalForm]],
  ExpressionUUID->"22664829-2b1e-43be-b953-23b99a2bb535"],
 " is a diagonal, non-negative matrix. The pseudo inverse of this matrix is \
then\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "+"], "=", 
    RowBox[{
     OverscriptBox["V", "\[LeftRightVector]"], " ", 
     SuperscriptBox[
      OverscriptBox["\[CapitalSigma]", "\[LeftRightVector]"], "+"], " ", 
     SuperscriptBox[
      OverscriptBox["U", "\[LeftRightVector]"], "T"]}]}], TraditionalForm]],
  ExpressionUUID->"11e62741-4a31-4050-a0b8-47e36104d68b"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], "+"], 
   TraditionalForm]],ExpressionUUID->"3ad1a87b-f568-4209-a387-cdd31af83e0c"],
 " is the pseudo-inverse of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], TraditionalForm]],
  ExpressionUUID->"37a8b1bc-223a-4dcf-9935-ad48b855df2e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["\[CapitalSigma]", "\[LeftRightVector]"], "+"], 
   TraditionalForm]],ExpressionUUID->"c600eb54-88a7-49d6-96f0-6052ac0d3fb3"],
 " is calculated by replacing all nonzero elements with their reciprocal and \
then transposing the resulting matrix. A final note: if ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalPhi]", "\[LeftRightVector]"], TraditionalForm]],
  ExpressionUUID->"48053241-c2f1-4a59-8df2-476f9175a4ab"],
 " is complex then we replace the transpose, ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "ebe0baf9-9795-4857-bad5-9f43eb5b3062"],
 " with conjugate transpose, ",
 Cell[BoxData[
  FormBox["\[Dagger]", TraditionalForm]],ExpressionUUID->
  "a6baeb6c-bab6-43a2-bb28-6687ccdcc8b0"],
 ".\n\nFinally, in order to quantify the \[OpenCurlyQuote]goodness of fit\
\[CloseCurlyQuote] we calculate the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "2"], TraditionalForm]],ExpressionUUID->
  "5a2cad03-e2c6-4e5b-b372-92b6f1e25368"],
 " value defined as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["R", "2"], "\[Congruent]", 
     RowBox[{"1", "-", 
      RowBox[{"\[ScriptCapitalL]", "/", 
       SuperscriptBox["\[Sigma]", "2"]}]}]}], "=", 
    RowBox[{"1", "-", 
     FractionBox[
      SuperscriptBox[
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "j"], "(", 
        RowBox[{
         SubscriptBox["y", "j"], "-", 
         SubscriptBox["f", "j"]}], ")"}], "2"], 
      SuperscriptBox[
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "j"], "(", 
        RowBox[{
         SubscriptBox["y", "j"], "-", 
         OverscriptBox["y", "_"]}], ")"}], "2"]]}]}], TraditionalForm]],
  ExpressionUUID->"12ee4990-c06e-4777-83e3-4a4227f67b9e"],
 "\n\nwhere\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["y", "_"], "\[Congruent]", 
    RowBox[{
     FractionBox["1", "N"], 
     SubscriptBox["\[CapitalSigma]", "n"], 
     SubscriptBox["y", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "cb9d4fe3-4ef9-4203-ba83-903014bd909a"],
 "\n\nis the mean value of the data points."
}], "Text",
 InitializationCell->True,
