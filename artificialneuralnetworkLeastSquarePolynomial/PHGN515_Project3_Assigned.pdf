   3.933376015339905*^9}, {3.9333761379602013`*^9, 3.9333761658257313`*^9}, {
   3.933376238477641*^9, 3.933376278966514*^9}, {3.933377018924665*^9, 
   3.933377089864656*^9}, {3.9333771403255*^9, 3.9333772080261374`*^9}, {
   3.933377331208658*^9, 3.93337744827428*^9}, {3.933377513698575*^9, 
   3.933377577595868*^9}, {3.933377627549954*^9, 3.933377720128796*^9}, {
   3.933377879959612*^9, 3.9333778800642014`*^9}, {3.933377924463332*^9, 
   3.9333779770758543`*^9}, {3.933380267167678*^9, 3.933380269407117*^9}, {
   3.933380384860224*^9, 3.93338038701519*^9}, {3.933380901725458*^9, 
   3.9333809530452414`*^9}, {3.933380986591753*^9, 3.933381000108931*^9}, {
   3.933381060784135*^9, 3.9333811005010643`*^9}, {3.933381155129381*^9, 
   3.933381417918159*^9}, {3.933381464082491*^9, 3.933381475787538*^9}, {
   3.933381636934041*^9, 3.933381637729189*^9}, {3.933381734995022*^9, 
   3.93338177311032*^9}, {3.933382003165802*^9, 3.933382031734171*^9}, {
   3.9333823200142403`*^9, 3.933382322147051*^9}, {3.9334310547521877`*^9, 
   3.9334312706019983`*^9}, {3.933431306917576*^9, 3.933431764534511*^9}, {
   3.9334318048984003`*^9, 3.933431870740138*^9}, {3.933431905448441*^9, 
   3.933431909692051*^9}, {3.933431954877384*^9, 3.9334319882896*^9}, {
   3.9334320583710737`*^9, 3.933432120014802*^9}, {3.933441474032042*^9, 
   3.933441490864532*^9}, 3.933441531159561*^9, {3.933441623094293*^9, 
   3.933441627810114*^9}, {3.93344169280229*^9, 3.933441698978558*^9}, {
   3.933441794583357*^9, 3.933441905696821*^9}, {3.9334419380824423`*^9, 
   3.933442181194412*^9}, {3.933442220580838*^9, 3.933442232399287*^9}, {
   3.933442270406568*^9, 3.933442340704103*^9}, {3.933442459495036*^9, 
   3.933442461773299*^9}, {3.933443273099494*^9, 3.933443358934016*^9}, {
   3.933443388971221*^9, 3.933443428962533*^9}, {3.933443811061771*^9, 
   3.933443834735187*^9}, {3.9334438770531807`*^9, 3.9334438967340717`*^9}, {
   3.933444061823283*^9, 3.933444142951277*^9}, {3.933444196723483*^9, 
   3.933444304905468*^9}, {3.9334444108496*^9, 3.933444413913625*^9}, {
   3.9334444545050707`*^9, 3.933444536271161*^9}, {3.9334445927256393`*^9, 
   3.9334446328287697`*^9}, {3.9334447041834307`*^9, 
   3.9334447041842537`*^9}, {3.933444878338601*^9, 3.933445000342553*^9}, {
   3.9334450311745872`*^9, 3.9334450444428*^9}, {3.9334451015840073`*^9, 
   3.9334451125291557`*^9}, {3.933445156715939*^9, 3.933445273953395*^9}, {
   3.933445311026271*^9, 3.933445324872986*^9}, {3.933445457423275*^9, 
   3.9334455242281322`*^9}, {3.933445788310358*^9, 3.933446186343507*^9}, {
   3.933446252886724*^9, 3.9334462803995028`*^9}, {3.933446335157872*^9, 
   3.933446392829646*^9}, {3.93344643572359*^9, 3.933446456832052*^9}, {
   3.9334466245651827`*^9, 3.9334466596318693`*^9}, {3.9334467382537518`*^9, 
   3.933446741170001*^9}, {3.933551703981921*^9, 3.9335517104779243`*^9}, {
   3.933551744006168*^9, 3.933551761752384*^9}, {3.933551795067827*^9, 
   3.933551854208829*^9}, {3.933551949025836*^9, 3.933552068141873*^9}, {
   3.9335524209426327`*^9, 3.933552456575193*^9}, {3.9336005504284763`*^9, 
   3.933600623701255*^9}, {3.9336006593570843`*^9, 3.933600692001191*^9}, {
   3.9336007837720833`*^9, 3.933600784424518*^9}, {3.9337684962104263`*^9, 
   3.933768532163528*^9}, {3.933768573003953*^9, 3.933768578517057*^9}, {
   3.933768644530546*^9, 3.933768724663562*^9}, {3.9337767491623573`*^9, 
   3.933776749309041*^9}, {3.9337772712391243`*^9, 3.9337773003982353`*^9}, {
   3.934041384132325*^9, 
   3.934041385183689*^9}},ExpressionUUID->"e953aef9-96eb-43b7-bc85-\
815e85739206"]
}, Closed]],

Cell[CellGroupData[{

Cell["Nonlinear least squares", "Subsubsection",
 CellChangeTimes->{{3.9336347707054043`*^9, 
  3.933634775179771*^9}},ExpressionUUID->"9892f6b8-9ad2-4545-92ed-\
857753e3ee13"],

Cell[TextData[{
 "This section sketches the process of nonlinear least squares methods. In \
practice, we will use a software package to perform nonlinear curve fitting.\n\
\nWhen the model function, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", 
    RowBox[{"x", ",", 
     OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "415617e2-32e8-475f-aa6c-c157d2c2e15e"],
 " depends nonlinearly on the model parameters, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Beta]", "\[RightVector]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40987d54-2b2a-4355-9c2a-f5d42d2d1c81"],
 " we cannot write a linear equation like above. In this case, we must resort \
to iterative methods.\n\nWe still define the residuals as,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "i"], "=", 
    RowBox[{
     SubscriptBox["y", "i"], "-", 
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", "i"], ",", 
       OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5c458287-b5bc-424e-a98f-b585fbb36259"],
 "\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "\[Element]", " ", "1"}], ",", "2", ",", "...", ",", "M"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f5b6801d-9c4d-4b95-aa40-2dc90fa748ac"],
 "\n\nwhere the measurements are in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f341be49-2535-4b2b-a29a-80ce5e00e377"],
 ", and the cost function is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", 
     RowBox[{
      OverscriptBox["y", "\[RightVector]"], ",", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubsuperscriptBox["r", "i", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7bf4e7de-d24f-46c1-9ffa-8f86b2a7d074"],
 "\n\nAs before, we minimize this w.r.t. the model parameters i.e.,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "j"]}]], "=", 
    RowBox[{"2", 
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubscriptBox["r", "i"], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["r", "i"]}], 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Beta]", "j"]}]]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "33535851-29ee-4610-a50d-0f93b5855a14"],
 "\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "\[Element]", " ", "1"}], ",", "2", ",", "...", ",", "N"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ac7b4891-e303-4bf9-abc1-45159e7f680a"],
 "\n\nhere we see ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", 
     SubscriptBox["r", "i"]}], 
    RowBox[{"\[PartialD]", 
     SubscriptBox["\[Beta]", "j"]}]], TraditionalForm]],ExpressionUUID->
  "044d717b-2fc6-4058-b67a-3366d4270428"],
 " can be considered a matrix of size MxN, where there are N model \
parameters. Since the model depends on N model-parameters, we have N gradient \
equations (rows). In this nonlinear system, the gradients are often functions \
of both the independent variable and the model parameters so, generally, \
there are no closed form solutions.\n\nIn iterative solutions methods, \
initial values are chosen for the model parameters that are then updated \
according to\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Beta]", "l", 
     RowBox[{"k", "+", "1"}]], "=", 
    RowBox[{
     SubsuperscriptBox["\[Beta]", "l", "k"], "+", 
     SubscriptBox["\[CapitalDelta]\[Beta]", "l"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "42dcb338-a4e0-4abd-870d-d79820e48a61"],
 "\n\nhere, k is the iteration number and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalDelta]\[Beta]", "l"], TraditionalForm]],
  ExpressionUUID->"a765d0d6-bc8d-4336-94a3-cc62adc1b04f"],
 " is the update. At each iteration, we linearize the model function by \
Taylor series approximation to first order about ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Beta]", "l", "k"], TraditionalForm]],ExpressionUUID->
  "2e995d50-7f15-406d-9c9f-c6fd12c69f04"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", "i"], ",", 
       SuperscriptBox[
        OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}], "+", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"f", "(", 
         RowBox[{
          SubscriptBox["x", "i"], ",", 
          SuperscriptBox[
           OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["\[Beta]", "j", "k"]}]], 
      RowBox[{"(", 
       RowBox[{
        SubsuperscriptBox["\[Beta]", "j", 
         RowBox[{"k", "+", "1"}]], "-", 
        SubsuperscriptBox["\[Beta]", "j", "k"]}], ")"}]}]}], "\[Congruent]", 
    RowBox[{
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", "i"], ",", 
       SuperscriptBox[
        OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}], "+", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], 
      SubscriptBox["J", 
       RowBox[{"i", ",", "j"}]], " ", 
      SubscriptBox["\[CapitalDelta]\[Beta]", "j"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bc2e7bdf-efbc-4e51-9286-a53f56355a6e"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", 
    RowBox[{"i", ",", "j"}]], TraditionalForm]],ExpressionUUID->
  "907df992-dff5-4578-850d-e169d8de514d"],
 " are the elements of the Jacobian and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalDelta]\[Beta]", "j"], TraditionalForm]],
  ExpressionUUID->"4a34ccee-0a06-435f-9bf4-635951cdc2c9"],
 " is the change in the model parameters over one iteration. Looking back at \
the residuals, we see that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["r", "i"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["\[Beta]", "j", "k"]}]], "=", 
    RowBox[{
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["\[Beta]", "j", "k"]}]], 
      RowBox[{"[", 
       RowBox[{
        SubscriptBox["y", "i"], "-", 
        RowBox[{"f", "(", 
         RowBox[{
          SubscriptBox["x", "i"], ",", 
          SuperscriptBox[
           OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}]}], 
       "]"}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        FractionBox["\[PartialD]", 
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["\[Beta]", "j", "k"]}]], 
        RowBox[{"f", "(", 
         RowBox[{
          SubscriptBox["x", "i"], ",", 
          SuperscriptBox[
           OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}]}]}], "=", 
      RowBox[{"-", 
       SubsuperscriptBox["J", 
        RowBox[{"i", ",", "j"}], "k"]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f87deec-e814-4e49-b4a6-dfd98e424f39"],
 "\n\nfor compactness of notation, we define\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]y", "i"], "\[Congruent]", 
    RowBox[{
     SubscriptBox["y", "i"], "-", 
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", "i"], ",", 
       SuperscriptBox[
        OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f4f2d579-785e-470e-9b47-d37dc038105e"],
 "\n\nwith these, the gradient equations become\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "j"]}]], "=", 
    RowBox[{
     RowBox[{"2", 
      SubscriptBox["\[CapitalSigma]", "i"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["r", "i"]}], 
       RowBox[{"\[PartialD]", 
        SubscriptBox["\[Beta]", "j"]}]], 
      SubscriptBox["r", "i"]}], "=", 
     RowBox[{
      RowBox[{"-", "2"}], 
      SubscriptBox["\[CapitalSigma]", "i"], 
      RowBox[{
       SubsuperscriptBox["J", 
        RowBox[{"i", ",", "j"}], "k"], " ", "[", 
       RowBox[{
        SubscriptBox["y", "i"], "-", 
        RowBox[{"f", "(", 
         RowBox[{
          SubscriptBox["x", "i"], ",", 
          OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}]}], "]"}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c634e102-ac26-4638-b0f8-02229aa96def"],
 "\n\ninserting the linearized approximation for the model function\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "j"]}]], "=", 
    RowBox[{
     RowBox[{"-", "2"}], 
     SubscriptBox["\[CapitalSigma]", "i"], 
     RowBox[{
      SubsuperscriptBox["J", 
       RowBox[{"i", ",", "j"}], "k"], "[", 
      RowBox[{
       SubscriptBox["y", "i"], "-", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"f", "(", 
          RowBox[{
           SubscriptBox["x", "i"], ",", 
           SuperscriptBox[
            OverscriptBox["\[Beta]", "\[RightVector]"], "k"]}], ")"}], "+", 
         RowBox[{
          SubscriptBox["\[CapitalSigma]", "s"], 
          SubsuperscriptBox["J", 
           RowBox[{"i", ",", "s"}], "k"], " ", 
          SubscriptBox["\[CapitalDelta]\[Beta]", "s"]}]}], "}"}]}], "]"}]}]}],
    TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "72556536-1205-40e3-902f-f9b0d5a07d4d"],
 "\n\ninserting ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalDelta]y", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c870f4d1-892c-4548-a709-7ff4f7b6afcf"],
 ", and simplifying a bit\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", "\[ScriptCapitalL]"}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "j"]}]], "=", 
    RowBox[{"2", 
     SubscriptBox["\[CapitalSigma]", "i"], 
     RowBox[{
      SubscriptBox["J", 
       RowBox[{"i", ",", "j"}]], " ", "[", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "s"], 
        SubscriptBox["J", 
         RowBox[{"i", ",", "s"}]], " ", 
        SubscriptBox["\[CapitalDelta]\[Beta]", "s"]}], "-", 
       SubscriptBox["\[CapitalDelta]y", "i"]}], "]"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7cc9fb91-a50e-4116-a30a-c760d4b15115"],
 "\n\nsetting this to zero and writing it in a matrix format, we get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["J", "\[LeftRightVector]"], "T"], " ", "[", 
     RowBox[{
      RowBox[{
       OverscriptBox["J", "\[LeftRightVector]"], " ", 
       OverscriptBox["\[CapitalDelta]\[Beta]", "\[RightVector]"]}], "-", 
      OverscriptBox["\[CapitalDelta]y", "\[RightVector]"]}], "]"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "63d5eb6e-ffdb-48a6-9ded-d73b31e013cf"],
 "\n\nand solving for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[CapitalDelta]\[Beta]", "\[RightVector]"], 
   TraditionalForm]],ExpressionUUID->"837d034c-951e-4007-95b1-79e591786dbf"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"  ", 
    RowBox[{
     OverscriptBox["\[CapitalDelta]\[Beta]", "\[RightVector]"], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          OverscriptBox["J", "\[LeftRightVector]"], "T"], 
         OverscriptBox["J", "\[LeftRightVector]"]}], ")"}], 
       RowBox[{"-", "1"}]], 
      SuperscriptBox[
       OverscriptBox["J", "\[LeftRightVector]"], "T"], 
      OverscriptBox["\[CapitalDelta]y", "\[RightVector]"]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5c4ae30a-2baa-4a6f-afad-c9016782dd37"],
 "\n\nThere is the lingering issue of calculating the Jacobian elements ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["\[PartialD]", 
     RowBox[{"\[PartialD]", 
      SubscriptBox["\[Beta]", "j"]}]], 
    RowBox[{"f", "(", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      OverscriptBox["\[Beta]", "\[RightVector]"]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"2d1f6478-7520-4ebb-b76d-dcd25b7f609f"],
 ". The following are methods to compute the Jacobian/Hessian used in \
nonlinear least squares\n\n1) Analytic\n2) Automatic differentiation\n3) \
Finite difference: Broyden\[CloseCurlyQuote]s update/Levenberg/Levenberg\
\[Dash]Marquardt methods\n\nYou can find a great overview of several \
techniques here:\n\
https://tobydriscoll.net/fnc-julia/nonlineqn/quasinewton.html#section-\
nonlineqn-quasinewton"
}], "Text",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQAWIQ/U9FWvqC31tH5SgBNRB94VKaDogOmSlhAKJfzM+1
A9G3ZN6B6R0T1aeA6Om8m2aAaJ2JngmPgfQnzkt5IHrJxlMzQfSXJfyrQPQ3
mVK/Z0D6kIZLDYi+uHBWJ4jeU+mwDUTX+xXuAdGneu8cBdGGr9dcANFljR8v
geiNNTuugWjmqe1PQDTPy3+/QPSVphn/QPSSo4d4ngPpP1JCIiA6zTlcEkRf
8AvWA9Hms1abgWgXb2FHEH2SuaUAROs5exeD6F2be2tA9LzZTL0g2ucx50QQ
/e6S0DwQPaW4fDOIbuDj2QaiO6xLjoPorkcrT4JoAO/SsGc=
  "],ExpressionUUID->"38e4ddee-fa64-4279-9a87-e8bf5487b9fc"]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Least Squares Approach: Complex Exponentials", "Subsection",
 CellChangeTimes->{{3.931563198110231*^9, 3.931563202547127*^9}, {
  3.931563392726397*^9, 3.931563409292445*^9}, {3.932937816163011*^9, 
  3.932937825909505*^9}, {3.932992494489414*^9, 3.9329924945632067`*^9}, {
  3.932992843136222*^9, 3.932992845942616*^9}, {3.932992889653348*^9, 
  3.9329928911075974`*^9}, {3.9337110221749763`*^9, 
  3.9337110233100853`*^9}},ExpressionUUID->"383bc13b-9c18-47b1-830d-\
ba519c4ea818"],

Cell[TextData[{
 "In a ",
 StyleBox["slightly",
  FontSlant->"Italic"],
 " different example, instead of using polynomials as basis functions, we use \
complex exponentials i.e., we decompose a function into complex exponentials, \
which we ",
 StyleBox["could",
  FontWeight->"Bold"],
 " write as:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     UnderscriptBox[
      OverscriptBox["\[CapitalSigma]", 
       RowBox[{
        RowBox[{"N", "/", "2"}], "-", "1"}]], 
      RowBox[{"n", "=", 
       RowBox[{
        RowBox[{"-", "N"}], "/", "2"}]}]], 
     SubscriptBox["c", "n"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", "n", " ", 
       FractionBox["x", "X"]}]]}]}], TraditionalForm]],ExpressionUUID->
  "774e5a3a-95b4-410a-a928-34bb41925b62"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"\[CapitalDelta]x", " ", "m"}]}], ",", " ", 
    RowBox[{"m", " ", "\[Element]", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "M"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"M", "/", "2"}], "-", "1"}]}], "]"}]}]}], TraditionalForm]],
  ExpressionUUID->"6f7736bc-d163-4184-83d2-c5e5ded44969"],
 ". We can define a \[OpenCurlyQuote]spatial\[CloseCurlyQuote] frequency ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "x"], "\[Congruent]", 
    RowBox[{"n", "/", "X"}], "\[Congruent]", 
    RowBox[{"n", " ", 
     SubscriptBox["\[CapitalDelta]f", "x"]}]}], TraditionalForm]],
  ExpressionUUID->"dc0d662d-43a7-411f-bee5-cd5c803eac0c"],
 ", and insert this\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{"\[CapitalSigma]", " ", 
     SubscriptBox["c", "n"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", 
       SubscriptBox["f", "x"], " ", "x"}]]}]}], TraditionalForm]],
  ExpressionUUID->"61677d23-85bd-411a-bdbd-b3fb15f02ad6"],
 "\n\nIn this exercise, we will use the M=N point decomposition. Where, now \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"\[CapitalDelta]x", " ", "m"}]}], ",", " ", 
    StyleBox[
     RowBox[{"m", " ", "\[Element]", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "N"}], "/", "2"}], ",", 
        RowBox[{
         RowBox[{"N", "/", "2"}], "-", "1"}]}], "]"}]}],
     FontWeight->"Bold"]}], TraditionalForm]],ExpressionUUID->
  "775dc9bf-e696-4c97-9726-a7cc1f00b3aa"],
 ". From above\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "x"], "=", 
    RowBox[{"n", " ", 
     SubscriptBox["\[CapitalDelta]f", "x"]}]}], TraditionalForm]],
  ExpressionUUID->"eaa068b3-58f3-4f66-80a6-30730518af3e"],
 "\n\nwith the frequency spacing given by (see note below about sampling and \
Nyquist frequencies)\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]f", "x"], "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["f", 
       RowBox[{"x", ",", " ", "max"}]], "N"], "=", 
     FractionBox["1", 
      RowBox[{"N", " ", "\[CapitalDelta]x"}]]}]}], TraditionalForm]],
  ExpressionUUID->"56a545cb-4470-49c5-a360-a974b0d0d746"],
 "\n\ninserting these relations into the basis decomposition, we get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "m"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "n"], " ", 
      SubscriptBox["c", "n"], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", 
        SubscriptBox["\[CapitalDelta]f", "x"], "m", " ", "\[CapitalDelta]x", 
        " ", "n"}]]}], "=", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "n"], " ", 
      SubscriptBox["c", "n"], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", 
        FractionBox[
         RowBox[{"m", " ", "n"}], "N"]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"4ed5c23c-8293-4679-aa41-c2d80b844c0d"],
 "\n\nwhere again, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "m"], "\[Congruent]", 
    RowBox[{"f", "(", 
     SubscriptBox["x", "m"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "be7c9cf1-9570-4505-a7e1-989051c8e073"],
 ", this can be written in matrix form as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["f", "1"]},
       {
        SubscriptBox["f", "2"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["f", "M"]}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox[
          RowBox[{"(", 
           SuperscriptBox["\[Omega]", 
            RowBox[{
             RowBox[{"-", "N"}], "/", "2"}]], ")"}], 
          RowBox[{
           RowBox[{"-", "M"}], "/", "2"}]], "\[Ellipsis]", "0", "\[Ellipsis]", 
         SuperscriptBox[
          RowBox[{"(", 
           SuperscriptBox["\[Omega]", 
            RowBox[{"N", "/", "2"}]], ")"}], 
          RowBox[{
           RowBox[{"-", "M"}], "/", "2"}]]},
        {"\[VerticalEllipsis]", "\[Ellipsis]", "\[VerticalEllipsis]", 
         "\[Ellipsis]", "\[VerticalEllipsis]"},
        {
         SuperscriptBox[
          RowBox[{"(", 
           SuperscriptBox["\[Omega]", 
            RowBox[{
             RowBox[{"-", "N"}], "/", "2"}]], ")"}], 
          RowBox[{"M", "/", "2"}]], "\[Ellipsis]", "0", "\[Ellipsis]", 
         SuperscriptBox[
          RowBox[{"(", 
           SuperscriptBox["\[Omega]", 
            RowBox[{"N", "/", "2"}]], ")"}], 
          RowBox[{"M", "/", "2"}]]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["c", "1"]},
        {
         SubscriptBox["c", "2"]},
        {"\[VerticalEllipsis]"},
        {
         SubscriptBox["c", "N"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ee6c257b-f586-4953-8c86-75252877f965"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "\[Congruent]", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "2", 
      RowBox[{"\[Pi]", "  ", "/", "N"}]}]]}], TraditionalForm]],
  ExpressionUUID->"1ecace2b-a771-4b3c-9ef7-16182c7e2982"],
 ". In symbolic matrix form, this would be\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["f", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["W", "\[LeftRightVector]"], 
     OverscriptBox["c", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"b47bbc10-aa46-4d7a-948f-89031b23d286"],
 "\n\nand, like in the case of polynomials, solving for the coefficient \
vector, we have\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["W", "\[LeftRightVector]"], "\[Dagger]"], 
        OverscriptBox["W", "\[LeftRightVector]"]}], ")"}], 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      OverscriptBox["W", "\[LeftRightVector]"], "\[Dagger]"], 
     OverscriptBox["f", "\[RightVector]"]}], "=", 
    OverscriptBox["c", "\[RightVector]"]}], TraditionalForm]],ExpressionUUID->
  "3076cc5a-5109-4408-a37e-864803279512"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox["\[Dagger]", TraditionalForm]],ExpressionUUID->
  "af8b8d61-d39d-4931-8c6f-1c1d089cc722"],
 " is the conjugate transpose. It turns out however, that ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["W", "\[LeftRightVector]"], TraditionalForm]],ExpressionUUID->
  "36c2c522-a1d5-459a-a2b3-97db261f379e"],
 " is Unitary, such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", "N"], 
     SuperscriptBox[
      OverscriptBox["W", "\[LeftRightVector]"], "\[Dagger]"], 
     OverscriptBox["W", "\[LeftRightVector]"]}], "=", 
    OverscriptBox["I", "\[LeftRightVector]"]}], TraditionalForm]],
  ExpressionUUID->"cf460aae-431f-4b69-a1b8-8a3eeb34a315"],
 ", and we can write\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["c", "\[RightVector]"], "=", 
    RowBox[{
     FractionBox["1", "N"], 
     SuperscriptBox[
      OverscriptBox["W", "\[LeftRightVector]"], "\[Dagger]"], 
     OverscriptBox["f", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"363d82ce-a5ff-4330-b392-5bea23238e1d"],
 "\n\nthis simply exchanges ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "2", 
      RowBox[{"\[Pi]", "/", "N"}]}]]}], TraditionalForm]],ExpressionUUID->
  "20a7934a-023f-4886-a036-5a05dd3caabe"],
 " with its complex conjugate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Omega]", "*"], "=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", "2", 
      RowBox[{"\[Pi]", "/", "N"}]}]]}], TraditionalForm]],ExpressionUUID->
  "7234db06-0f6a-4584-a87c-53888e250361"],
 ". This means the product of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["W", "\[LeftRightVector]"], "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"3e666d74-f355-4621-8af9-2becee1a9243"],
 " with ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["f", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "9d8ae2ab-2d00-40d1-8c49-93bc16d399ba"],
 " gives\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "m"], "=", 
    RowBox[{
     FractionBox["1", "N"], 
     SubscriptBox["\[CapitalSigma]", "n"], " ", 
     SubscriptBox["f", "n"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", 
       FractionBox[
        RowBox[{"m", " ", "n"}], "N"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"dea072e0-392d-4f37-91d7-6983128eda91"],
 "\n\nwhich are ",
 ButtonBox["Fourier series coefficients",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Fourier_series#Exponential_form_\
coefficients"], None},
  ButtonNote->
   "https://en.wikipedia.org/wiki/Fourier_series#Exponential_form_\
coefficients"],
 ". Where, the fundamental frequency of integration is 1/N. If we allow ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "->", "\[Infinity]"}], TraditionalForm]],ExpressionUUID->
  "57aac5f3-22da-46ee-9486-d5368802d07b"],
 " in both the present expression, and the original series expansion, then \
the divisions between pixel spacing become infinitesimal and we retrieve \
Fourier transform pairs."
}], "Text",
 CellChangeTimes->CompressedData["
1:eJwl0n0s1AEAxvHDKVGhuAqnF/KSi/OWnZdyahRhsrzlbSId5kYUlZaXnJ23
Gc5S6iaZvIymjiRci6ERdl42tLM6iujEMBX9nl9/PPv8+/zxPRrBvRSlSKFQ
2MRgxbhHv77nIvudfPUT1HU4LYE0403S8iuSSdiloTMDRxb3L8ASTZslGG5A
UThMKPBMpMHAskwGHOVFMeHuFDoLBrUo2MOMmjkPOFnqEwiVF+xCYA7rVASs
YvBiobl5PmnEM/U0qGPRmAXP6+XnwLEXlUVQt87kMxT+dZ+BS+vyXjnhWs7N
j/AhfWoO1si4a3BI/HQT6qkpbcFkfYH6MiE94J42DLG21YE7rWtNoU+20BKW
xI9Yw7BzuY6wq3rsDOTZ9pyFtU7/FRVXX4C98wOkFGoHd5XQ1SQmBcrnJ7Rq
vBbZxusm2rBPFncIPu54TvpE8tsUemVwGFBwxN0SWiXW28DkBnV7WNrt4gRd
