  PlotRange->{{0, 356.}, {
    0, 396.}}]], \
"Input",ExpressionUUID->"96540493-3664-417e-9a92-2fcb78fce7f5"]], "Text",
 CellChangeTimes->{
  3.933712151099555*^9, {3.933712197387164*^9, 3.9337121975062933`*^9}, {
   3.933712639532292*^9, 3.933712639718854*^9}, {3.933713990728135*^9, 
   3.933713990936364*^9}, {3.933714069987183*^9, 3.9337140701220207`*^9}, {
   3.933715728028404*^9, 
   3.9337157282068987`*^9}},ExpressionUUID->"9fae6a2b-4fcd-49cc-928a-\
30082dcd6acb"],

Cell[TextData[{
 "The figure above is an example of an ANN that can fit data in a vector ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["y", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "fbdf3241-a9e2-43ee-8b85-48a7ed09fdfe"],
 ", with a polynomial of order 2. The only weight matrix \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["W", "\[LeftRightVector]"], "\[Congruent]", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["w", 
         RowBox[{"1", ",", "1"}]], 
        SubscriptBox["w", 
         RowBox[{"1", ",", "2"}]], 
        SubscriptBox["w", 
         RowBox[{"1", ",", "3"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "57f38c81-8b57-4dfe-b9d2-4fdf7fc9054e"],
 "\n\nmultiplies the input ",
 StyleBox["column",
  FontWeight->"Bold"],
 "-vector after which, a bias \[OpenCurlyQuote]vector\[CloseCurlyQuote] \
(which is actually a scalar in this case)\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["b", "\[RightVector]"], "\[Congruent]", "b"}], 
   TraditionalForm]],ExpressionUUID->"1051d48b-4985-4cda-a360-75deb40337a2"],
 "\n\nis added. The result of the calculation is the activation in the output \
layer and is written in math as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", 
    RowBox[{"\[Sigma]", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "j"], 
       SubscriptBox["W", 
        RowBox[{"i", ",", "j"}]], 
       SubscriptBox["INPUT", "j"]}], "+", "b"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"609b2286-f458-4a89-8f4d-e9c71ac006ee"],
 "\n\nIn this case, the activation function is linear. That is to say, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Sigma]", "(", "z", ")"}], "=", "z"}], TraditionalForm]],
  ExpressionUUID->"42a2552f-81a7-4c3c-9957-275000f3ecac"],
 ", it just returns the input. So we could write\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], 
      SubscriptBox["W", 
       RowBox[{"i", ",", "j"}]], 
      SubscriptBox["INPUT", "j"]}], "+", "b"}]}], TraditionalForm]],
  ExpressionUUID->"f6c4d6c5-755f-47a0-8930-989820ea9d71"],
 "\n\nIt is important to note that ",
 StyleBox["ONE",
  FontWeight->"Bold"],
 " x-value (e.g., ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],ExpressionUUID->
  "bf8e7826-5510-464c-b3c1-a643f90a2f85"],
 " or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "444b20df-f791-4d6d-8eb7-24295aa85ad4"],
 " but NOT ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],ExpressionUUID->
  "1c44721c-257a-4389-9d3c-7b0c42e0401e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "e5ec98e3-3f06-4b31-bf8a-abb785678ff1"],
 ") is fed into the ANN at a time.\n\nRead that sentence again...slowly.\n\n\
This is why I wrote the equations above using ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["INPUT", "j"], TraditionalForm]],ExpressionUUID->
  "8c9ffa86-9c3d-4475-90e2-5cb2b00188cf"],
 ", to (hopefully) avoid confusion. Here\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["INPUT", "j"], "=", 
    RowBox[{
     SubsuperscriptBox["x", "n", "j"], "    ", 
     OverscriptBox["\[DoubleLongRightArrow]", 
      RowBox[{"For", " ", "example"}]], "   ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SubsuperscriptBox["x", "1", "j"], ",", 
        SubsuperscriptBox["x", "2", "j"], ","}], "\[InvisibleComma]", 
       RowBox[{"...", ",", 
        SubsuperscriptBox["x", "N", "J"]}]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"9cd6d9ad-567a-4955-a297-781dae3a0291"],
 "\n\nIn other words, the input node values are ONE value of \
\[OpenCurlyQuote]",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "fc2c7ad7-13e5-445e-8599-6db05d1c7d99"],
 "\[CloseCurlyQuote] (for instance, the first x-point i.e., ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],ExpressionUUID->
  "980b34d3-e9f7-4091-bc87-ff3c6a731c9a"],
 "), raised to the power of the node index (zero indexed). The output is \
calculated for ALL x-values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["x", "n"], "|", 
       RowBox[{"n", "\[Element]", "\[DoubleStruckCapitalN]"}]}], ",", 
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"], ","}], "\[InvisibleComma]", 
     RowBox[{"...", ",", 
      SubscriptBox["x", "N"]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "4a12935c-5d1f-44f3-bee7-0150bcd6cc2a"],
 " and then the gradients are averaged over all input x-values. The weight \
\[OpenCurlyQuote]matrix\[CloseCurlyQuote] is then just the coefficients for \
the basis function expansion.\n\nThe ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "th"], TraditionalForm]],ExpressionUUID->
  "09cf71eb-0a6a-44e5-823a-299342c1dc3e"],
 " cost function in this case is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "n"], "-", 
        SubscriptBox["y", "n"]}], ")"}], "2"], "=", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
         SubscriptBox["W", 
          RowBox[{"1", ",", "\[Mu]"}]], 
         SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b", "-", 
        SubscriptBox["y", "n"]}], ")"}], "2"]}]}], TraditionalForm]],
  ExpressionUUID->"8320b8f0-a3bd-49b5-9cdc-2385a9bebf20"],
 "\n\nsimplified\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
        SubscriptBox["W", "\[Mu]"], 
        SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b", "-", 
       SubscriptBox["y", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"53c60914-ebb7-4135-a4db-c11d4f9769f7"],
 "\n\nthe gradients are calculated using the fact that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"\[Sigma]", "(", 
       SubsuperscriptBox["z", "j", 
        RowBox[{"(", "P", ")"}]], ")"}]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", 
       RowBox[{"(", "P", ")"}]]}]], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"471ed25a-e85a-4b6b-a643-99048dddedc8"],
 ",\n\nwhich gives\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["w", 
       RowBox[{
        RowBox[{"1", ","}], " ", "\[InvisibleComma]", "k"}]]}]], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["a", "k", 
       RowBox[{"(", 
        RowBox[{"P", "-", "1"}], ")"}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "j", 
          RowBox[{"(", "P", ")"}]], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "j", 
         RowBox[{"(", "P", ")"}]]}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", 
         RowBox[{"(", "P", ")"}]]}]]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["INPUT", "k"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubscriptBox["C", "n"]}], 
        RowBox[{"\[PartialD]", 
         SuperscriptBox["a", 
          RowBox[{"(", "P", ")"}]]}]]}], "=", 
      RowBox[{
       RowBox[{"2", 
        SubsuperscriptBox["x", "n", "k"], " ", 
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["a", "n"], "-", 
          SubscriptBox["y", "n"]}], ")"}]}], "=", 
       RowBox[{"2", 
        RowBox[{
         SubsuperscriptBox["x", "n", "k"], " ", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
             SubscriptBox["W", 
              RowBox[{"1", ",", "\[Mu]"}]], 
             SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
          SubscriptBox["y", "n"]}], "]"}]}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"a08a0c9e-275b-43e9-8cd2-4ca2dbab15f7"],
 "\n\nsimplified, we have\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["w", 
       RowBox[{"\[InvisibleComma]", "k"}]]}]], "=", 
    RowBox[{"2", 
     RowBox[{
      SubsuperscriptBox["x", "n", "k"], " ", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
          SubscriptBox["W", "\[Mu]"], 
          SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
       SubscriptBox["y", "n"]}], "]"}]}]}], TraditionalForm]],
  Background->GrayLevel[0.85],ExpressionUUID->
  "f47c4a80-87d5-464e-9e50-99603a66afb0"],
 "\n\nand\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["b", 
       RowBox[{"(", "P", ")"}]]}]], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "j", 
          RowBox[{"(", "P", ")"}]], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "j", 
         RowBox[{"(", "P", ")"}]]}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", 
         RowBox[{"(", "P", ")"}]]}]]}], "=", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "n"], "-", 
         SubscriptBox["y", "n"]}], ")"}]}], "=", 
      RowBox[{"2", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
           SubscriptBox["W", 
            RowBox[{"1", ",", "\[Mu]"}]], 
           SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
        SubscriptBox["y", "n"]}], "]"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"aa10292b-7464-4b82-ba9a-8b3f711248be"],
 "\n\nsimplified\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", "b"}]], "=", 
    RowBox[{"2", " ", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
         SubscriptBox["W", "\[Mu]"], 
         SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
      SubscriptBox["y", "n"]}], "]"}]}], TraditionalForm]],
  Background->GrayLevel[0.85],ExpressionUUID->
  "dedbf58f-f9e9-4f29-8d30-43181392168c"],
 "\n\nIf we wanted, we could calculate this result first, and then insert it \
into the previous one e.g.,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox["w", 
       RowBox[{"\[InvisibleComma]", "k"}]]}]], "=", 
    RowBox[{
     SubsuperscriptBox["x", "n", "k"], " ", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", "b"}]]}]}], TraditionalForm]],ExpressionUUID->
  "43b06f08-62c6-4bbd-b10a-09ed8adc03c8"],
 "\n\nand, as a reminder\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["w", "k"], "\[LeftArrow]", 
     RowBox[{
      SubscriptBox["w", "k"], "-", 
      RowBox[{
       FractionBox["\[Omega]", "N"], " ", 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", " ", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["x", "n", "k"], " ", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", "b"}]]}], "=", 
     RowBox[{
      SubscriptBox["w", "k"], "-", 
      RowBox[{"2", 
       FractionBox["\[Omega]", "N"], " ", 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", " ", 
    RowBox[{
     SubsuperscriptBox["x", "n", "k"], "  ", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
         SubscriptBox["W", "\[Mu]"], 
         SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
      SubscriptBox["y", "n"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "99feb4df-8df3-42a5-a767-786279d16352"],
 "\n\nand similarly for the biases\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"b", "\[LeftArrow]", 
     RowBox[{"b", "-", 
      RowBox[{
       FractionBox["\[Beta]", "N"], " ", 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", "b"}]], "=", 
     RowBox[{"b", "-", 
      RowBox[{"2", 
       FractionBox["\[Beta]", "N"], " ", 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", "  ", 
    
    RowBox[{"[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
         SubscriptBox["W", "\[Mu]"], 
         SubsuperscriptBox["x", "n", "\[Mu]"]}], "+", "b"}], ")"}], "-", 
      SubscriptBox["y", "n"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "1bb2c8ed-6cee-4278-ac50-c77dfbe8ce6c"]
}], "Text",
 CellChangeTimes->CompressedData["
1:eJwdzlkowwEAx/HZIrR5oGRlhWUPGrkejFJjYmii5VzRjC0lkzUt5W7WxgMe
pCmJ3EfIMeXKllvN1pTCyqJlpAxpC//fHn59Xn4P32hxU0kdmUQiMYhBXmD2
46fglTvfWOaAWnWpE5bTxl3wd4TD/CJc7uL67E3Qp0Dxzb3P+sW5NBhlUgqg
u62rCjaoA6rhiTJ1Fm63iBZgHC9oF8pl2gM4Ra+8hC5p/xVUtY5ZID033QkV
+84f6JWw/b7xr6ZOw3az7AL6F/PNkOLx2uG7Jn/CQ7ilc05CjdA4AzlihgGy
PGGHkEop9plcYT2Dnfz4N2iKFHzAJ5XNDTd4GX+w1i4hewnXrBnBcG+JFQKZ
oTkM2HM3mgQTWtuzoLlAkQcjrLeF8HhHJ4SxMepyuLkqr4G062YVFDnWO2DK
g1sNjQ8rg3DbMGAJLyK6HAU2OJTY/QxjM/Uv8Jz9fDRMOC7tO4X/sMoCfw==

  "],ExpressionUUID->"d6d8c9ec-5fd9-4226-b0fc-163c715523d5"],

Cell[CellGroupData[{

Cell["Back propagation derivation (first order methods)", "Subsubsection",
 CellChangeTimes->{{3.9337071911078167`*^9, 3.93370719454666*^9}, {
  3.933707228427454*^9, 3.933707231458068*^9}, {3.9337249536211157`*^9, 
  3.9337249546250563`*^9}},ExpressionUUID->"9bfdd36f-3c76-427b-a11f-\
ff3fa4dfa924"],

Cell[TextData[{
 "The update for the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6bae571c-442c-43f9-ac56-772cd25c6d9f"],
 " node at the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5627c61a-2d19-46b9-ae82-d44680204a1f"],
 " layer is given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "j", "p"], "=", 
    RowBox[{"\[Sigma]", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "p"], 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"p", "-", "1"}]]}], "+", 
      SubsuperscriptBox["b", "j", "p"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"1ba686a8-233c-4ec2-85cf-09aaef5245f7"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "j", "p"], TraditionalForm]],ExpressionUUID->
  "d48863a5-1c70-4486-a08e-0d121d2d92e4"],
 " is a colum vector with ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"j", "\[Element]", 
     RowBox[{"[", 
      RowBox[{"1", ",", "J"}], "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "e73ba1d7-db69-4170-b531-0a7c3fc039dc"],
 ". Define\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["z", "j", "p"], "\[Congruent]", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "p"], 
      SubsuperscriptBox["a", "\[Mu]", 
       RowBox[{"p", "-", "1"}]]}], "+", 
     SubsuperscriptBox["b", "j", "p"]}]}], TraditionalForm]],ExpressionUUID->
  "5a99255e-56ef-48eb-a8e7-626d71eeb540"],
 "\n\nthen\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "j", "p"], "=", 
    RowBox[{"\[Sigma]", "(", 
     SubsuperscriptBox["z", "j", "p"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"340f317f-8ce1-4225-86a6-aba50281d7c3"],
 "\n\nwhere \[Sigma] is the activation function. Now, define the nth cost \
metric at the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["P", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "745e7eff-c48c-421c-b528-98cc6155957e"],
 " (final) layer as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox["a", "j", "P"], "-", 
         SubsuperscriptBox["y", "j", "n"]}], ")"}], "2"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "j"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Sigma]", "(", 
           SubsuperscriptBox["z", "j", "P"], ")"}], "-", 
          SubsuperscriptBox["y", "j", "n"]}], ")"}], "2"]}], "=", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "j"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Sigma]", "(", 
           RowBox[{
            RowBox[{
             SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
             SubsuperscriptBox["w", 
              RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "P"], 
             SubsuperscriptBox["a", "\[Mu]", 
              RowBox[{"P", "-", "1"}]]}], "+", 
            SubsuperscriptBox["b", "j", "P"]}], ")"}], "-", 
          SubsuperscriptBox["y", "j", "n"]}], ")"}], "2"]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"a6bf4fc7-b859-415c-b971-5d4c2b207ff4"],
 "\n\nwe now calculate the derivate of the nth cost function for the current \
activation in the current layer and any activation in the previous layer. We \
call that particular weight ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["w", 
    RowBox[{"j", "\[InvisibleComma]", "k"}], "P"], TraditionalForm]],
  ExpressionUUID->"18e8941f-b606-4b7f-b23e-cd516a1ba897"],
 " where we keep the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d6779ea2-c662-4c62-84bc-98471e4e006d"],
 " index to represent \[OpenCurlyQuote]this layer\[CloseCurlyQuote] and ",
 StyleBox["k",
  FontSlant->"Italic"],
 " as the index for the previous layer. Using the chain rule\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]]}]}], 
   TraditionalForm]],ExpressionUUID->"1a366643-769e-42a0-a797-e71051720695"],
 "\n\nnoting that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "j", "p"], "=", 
    RowBox[{"\[Sigma]", "(", 
     SubsuperscriptBox["z", "j", "p"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"c0500a02-a315-4891-b0de-69767b5f13bc"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "P"]}], 
     RowBox[{"\[PartialD]", 
      RowBox[{"\[Sigma]", "(", 
       SubsuperscriptBox["z", "j", "P"], ")"}]}]], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"0731b52e-599d-466d-ad60-1e7929d18fa6"],
 ", so we get\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]]}]}], 
   TraditionalForm]],ExpressionUUID->"b22fd62d-80b2-4d5f-a198-3348e0de0302"],
 "\n\nagain, inserting the above definition, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "j", "P"], "=", 
    RowBox[{"\[Sigma]", "(", 
     SubsuperscriptBox["z", "j", "P"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"e155ad9f-3198-4b60-b112-728d8434bb10"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]]}]}], 
   TraditionalForm]],ExpressionUUID->"7d409346-14ab-44bb-9704-45ca87475298"],
 "\n\nwe know that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", "P"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox["\[PartialD]", 
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["w", 
           RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], 
        SubscriptBox["\[CapitalSigma]", "\[Mu]"]}], 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "P"], 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"P", "-", "1"}]]}], "+", 
      SubsuperscriptBox["b", "j", "P"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"P", "-", "1"}]], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["w", 
          RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "P"]}], 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["w", 
          RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
        SubsuperscriptBox["a", "\[Mu]", 
         RowBox[{"P", "-", "1"}]], 
        SubscriptBox["\[Delta]", 
         RowBox[{"\[Mu]", "\[InvisibleComma]", "k"}]]}], "=", 
       SubsuperscriptBox["a", "k", 
        RowBox[{"P", "-", "1"}]]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "fc95790f-624d-468e-814e-acc4ef706643"],
 "\n\nor, in short\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", "P"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    SubsuperscriptBox["a", "k", 
     RowBox[{"P", "-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "5d6857d2-05db-43bb-be5b-ada7538538c0"],
 "\n\ninserting this into the derivative\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     SubsuperscriptBox["a", "k", 
      RowBox[{"P", "-", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"e49a3efc-a521-47f1-9f87-1e2ed340eb84"],
 "\n\nnow we are left with calculating the last derivative\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "P"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["a", "j", "P"]}]], 
       SubscriptBox["\[CapitalSigma]", "\[Mu]"]}], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
         SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], "2"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
       RowBox[{
        FractionBox["\[PartialD]", 
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["a", "j", "P"]}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
           SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], "2"]}]}], "=", 
      RowBox[{
       RowBox[{"2", 
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
        RowBox[{"(", 
         RowBox[{
          SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
          SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], 
        FractionBox[
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["a", "\[Mu]", "P"]}], 
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["a", "j", "P"]}]]}], "=", 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
         RowBox[{"(", 
          RowBox[{
           SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
           SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], 
         SubscriptBox["\[Delta]", 
          RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}]]}], "=", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           SubsuperscriptBox["a", "j", "P"], "-", 
           SubsuperscriptBox["y", "j", "n"]}], ")"}]}]}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"54c6af3d-c359-464e-83c7-d5273b075501"],
 "\n\ninserting this into the derivative, we now have the gradient of the \
cost w.r.t. the weights\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{"2", 
     SubsuperscriptBox["a", "k", 
      RowBox[{"P", "-", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["a", "j", "P"], "-", 
       SubsuperscriptBox["y", "j", "n"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9d2fad52-ef8f-4930-b684-3770c60e3bd0"],
 "\n\nNow, everything we just did was quite general until the last step. That \
is to say, we could start with\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "P"]}]], "=", 
    RowBox[{
     SubsuperscriptBox["a", "k", 
      RowBox[{"P", "-", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"66b50d0b-b486-499a-a8dc-94422eb67bb4"],
 "\n\nand change P (upper case) for p (lower case)\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "p"]}]], "=", 
    RowBox[{
     SubsuperscriptBox["a", "k", 
      RowBox[{"p", "-", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "p"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "p"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "p"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"0aa22e60-c48f-48e1-b136-9222b797ff00"],
 "\n\nand the only thing that needs to change is ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", 
     SubscriptBox["C", "n"]}], 
    RowBox[{"\[PartialD]", 
     SubsuperscriptBox["a", "j", "p"]}]], TraditionalForm]],ExpressionUUID->
  "201cfe59-3b68-44e1-869d-80ebc67c9fa0"],
 ". Again using the cost function\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "n"], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
        SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"463c6610-8462-4ee1-b04e-8fa51d3577e7"],
 "\n\nwe can calculate\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "p"]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["a", "j", "p"]}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
          SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], "2"]}]}], "=", 
     RowBox[{"2", 
      SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
      RowBox[{"(", 
       RowBox[{
        SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
        SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "\[Mu]", "P"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", "p"]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"14eefde1-85a9-482f-9051-6f12044d78cb"],
 "\n\nand now using\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "\[Mu]", "P"], "=", 
    RowBox[{"\[Sigma]", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "k"], 
       SubsuperscriptBox["w", 
        RowBox[{"\[Mu]", "\[InvisibleComma]", "k"}], "P"], 
       SubsuperscriptBox["a", "k", 
        RowBox[{"P", "-", "1"}]]}], "+", 
      SubsuperscriptBox["b", "\[Mu]", "P"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"873ce657-afce-46b3-9018-f57bacd45081"],
 "\n\nthe derivative is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "\[Mu]", "P"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "p"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "p"]}]], "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"\[PartialD]", " ", 
         RowBox[{"\[Sigma]", "(", 
          SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["z", "\[Mu]", "P"]}], 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["a", "j", "p"]}]]}], "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[PartialD]", " ", 
          RowBox[{"\[Sigma]", "(", 
           SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
        RowBox[{
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
           SubsuperscriptBox["a", "j", "p"]}]], 
         SubscriptBox["\[CapitalSigma]", "k"]}], 
        SubsuperscriptBox["w", 
         RowBox[{"\[Mu]", "\[InvisibleComma]", "k"}], "P"], 
        SubsuperscriptBox["a", "k", 
         RowBox[{"P", "-", "1"}]]}], "+", 
       SubsuperscriptBox["b", "\[Mu]", "P"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"edb9cc44-339f-485e-afdc-c3f0eed3ec18"],
 "\n\nwhich gives\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "p"]}]]}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], "[", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "k"], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "k", 
         RowBox[{"P", "-", "1"}]]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", "p"]}]], 
      SubsuperscriptBox["w", 
       RowBox[{"\[Mu]", "\[InvisibleComma]", "k"}], "P"]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"b0d0de40-2994-4ee9-ba15-95f5e0c5c260"],
 "\n\nwe see that when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"P", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "7687fcab-c16e-4c42-8f3a-36fa9ac3eeb5"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "p"]}]]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", " ", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "\[Mu]", "P"]}]], "[", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "k"], 
       SubscriptBox["\[Delta]", 
        RowBox[{"k", "\[InvisibleComma]", "j"}]], 
       SubsuperscriptBox["w", 
        RowBox[{"\[Mu]", "\[InvisibleComma]", "k"}], "P"]}], "]"}], "=", 
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", " ", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
      SubsuperscriptBox["w", 
       RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], "P"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"b1e71be3-15b4-486a-9bd5-ea842939302e"],
 "\n\nthen\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", 
       RowBox[{"P", "-", "1"}]]}]], "=", 
    RowBox[{"2", 
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], "P"], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["a", "\[Mu]", "P"], "-", 
       SubsuperscriptBox["y", "\[Mu]", "n"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9d897e47-47e8-4a8c-91e8-3ebe712368fd"],
 "\n\nwhich we can write using\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "P"]}]], "=", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["a", "j", "P"], "-", 
       SubsuperscriptBox["y", "j", "n"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"eee62fed-c005-427b-818b-f998a1a88e07"],
 "\n\nas\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", 
       RowBox[{"P", "-", "1"}]]}]], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], "P"], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "\[Mu]", "P"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"f92736c4-978d-4cf7-b8c9-9820521fc5a5"],
 "\n\nbecause there is no reference to the output (i.e., everything here is \
general), there is nothing \[OpenCurlyQuote]special\[CloseCurlyQuote] about P \
so now we set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"P", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "a1546151-d422-4cf0-813e-9d1144e8b95e"],
 ", or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{"p", "+", "1"}]}], TraditionalForm]],ExpressionUUID->
  "d61b8e64-c108-4ccc-8286-31657f139a28"],
 ", and inserting\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "p"]}]], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], 
      RowBox[{"p", "+", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", 
         RowBox[{"p", "+", "1"}]], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]]}]}], TraditionalForm]],ExpressionUUID->
  "86a3f557-e89f-46ab-9b2e-2f26cfd470a4"],
 "\n\nNow we repeat this for the biases. Starting with the gradient of the \
cost function w.r.t. the bias\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["b", "w", "P"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["b", "w", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "P"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"05d39397-72a7-453d-bb71-3411439907a0"],
 "\n\nnow, each of these is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", "P"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["b", "w", "P"]}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["b", "w", "P"]}]], 
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"p", "-", "1"}]], 
       SubsuperscriptBox["w", 
        RowBox[{"j", "\[InvisibleComma]", "\[Mu]"}], "p"]}], "+", 
      SubsuperscriptBox["b", "j", "p"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["b", "j", "p"]}], 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox["b", "w", "P"]}]]}], "=", "1"}]}]}], 
   TraditionalForm]],ExpressionUUID->"f093baca-6d1c-4fa6-823a-1aba3384c2db"],
 "\n\nthe second term is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "P"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", "P"]}]], "=", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"\[Sigma]", "(", 
       SubsuperscriptBox["z", "j", "P"], ")"}]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["z", "j", "P"]}]]}], TraditionalForm]],ExpressionUUID->
  "681e0762-387e-42ef-8d51-c3f5b414785c"],
 "\n\nand, as before, the last term is\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "p"]}]], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], 
      RowBox[{"p", "+", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", 
         RowBox[{"p", "+", "1"}]], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]]}]}], TraditionalForm]],ExpressionUUID->
  "e9a70452-eaba-430d-83c3-1f2e4b25a044"],
 "\n\nputting this all together and relabeling P for p\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["b", "w", "p"]}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "j", "p"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "j", "p"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"1f346406-eb1f-459b-8340-0800dd3713e8"],
 "\n\nThen the updates for the weights at the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b45b9100-5d86-48fc-8a69-c27c410f9bb3"],
 " layer are\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["w", 
      RowBox[{"j", "\[InvisibleComma]", "k"}], "p"], "=", 
     RowBox[{
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "p"], "-", 
      RowBox[{
       FractionBox["\[Omega]", "N"], 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "p"]}]]}], TraditionalForm]],
  ExpressionUUID->"b2c2222a-d594-4722-99d6-4a9abf14996d"],
 "\n\nand similarly for the biases\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["b", "j", "p"], "=", 
     RowBox[{
      SubsuperscriptBox["b", "j", "p"], "-", 
      RowBox[{
       FractionBox["\[Beta]", "N"], " ", 
       SubscriptBox["\[CapitalSigma]", "n"]}]}]}], "\[InvisibleComma]", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["b", "j", "p"]}]]}], TraditionalForm]],ExpressionUUID->
  "866412b1-11e2-44b3-90b7-2983fa833e3f"],
 "\n\nwhere \[Omega], \[Beta] are dubbed \[OpenCurlyQuote]learning rates\
\[CloseCurlyQuote]. With the gradients given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["w", 
       RowBox[{"j", "\[InvisibleComma]", "k"}], "p"]}]], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["a", "k", 
       RowBox[{"p", "-", "1"}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "j", "p"], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "j", "p"]}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", "p"]}]]}], "=", 
     RowBox[{
      SubsuperscriptBox["a", "k", 
       RowBox[{"p", "-", "1"}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "j", "p"]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"2662b9c1-e1fa-4792-96d0-875043562ef2"],
 "\n\nand\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["b", "j", "p"]}]], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{"\[Sigma]", "(", 
         SubsuperscriptBox["z", "j", "p"], ")"}]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["z", "j", "p"]}]], 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SubscriptBox["C", "n"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox["a", "j", "p"]}]]}], "=", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "j", "p"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"8bedcb02-bf49-4f35-9006-658e2fce116d"],
 "\n\nboth sharing,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "p"]}]], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], 
      RowBox[{"p", "+", "1"}]], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", 
         RowBox[{"p", "+", "1"}]], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "\[Mu]", 
        RowBox[{"p", "+", "1"}]]}]]}]}], TraditionalForm]],ExpressionUUID->
  "6bc54e72-a7bd-4dd6-b091-1bfb4e3387b5"],
 "\t\tand\t\t",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[PartialD]", 
     RowBox[{"\[Sigma]", "(", 
      SubsuperscriptBox["z", "j", "P"], ")"}]}], 
    RowBox[{"\[PartialD]", 
     SubsuperscriptBox["z", "j", "P"]}]], TraditionalForm]],ExpressionUUID->
  "49fa6f7c-b159-4703-b8e4-dd781de2c0b7"],
 "\n\nand remembering that when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{"p", "+", "1"}]}], TraditionalForm]],ExpressionUUID->
  "e5e7644c-9e36-43c7-9c6e-23c19c1fdb91"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", 
       RowBox[{"P", "-", "1"}]]}]], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Mu]"], " ", 
     SubsuperscriptBox["w", 
      RowBox[{"\[Mu]", "\[InvisibleComma]", "j"}], "P"], 
     FractionBox[
      RowBox[{"\[PartialD]", " ", 
       RowBox[{"\[Sigma]", "(", 
        SubsuperscriptBox["z", "\[Mu]", "P"], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["z", "\[Mu]", "P"]}]], 
     FractionBox[
      RowBox[{"\[PartialD]", 
       SubscriptBox["C", "n"]}], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox["a", "\[Mu]", "P"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"dd60f725-dab9-415e-b4ef-e2c3b864d7f6"],
 "\n\nwith\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox["C", "n"]}], 
     RowBox[{"\[PartialD]", 
      SubsuperscriptBox["a", "j", "P"]}]], "=", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["a", "j", "P"], "-", 
       SubsuperscriptBox["y", "j", "n"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e140aba2-1a97-4c5f-9af5-6673a3197668"]
}], "Text",
 CellChangeTimes->{{3.9337072325868196`*^9, 3.933707245481666*^9}, {
   3.9340356577234173`*^9, 3.93403569995345*^9}, 3.934035743705943*^9, {
   3.9340357767953043`*^9, 3.934035776796844*^9}, {3.9340358511383877`*^9, 
   3.934035896497918*^9}},ExpressionUUID->"2d08d6b4-4329-4965-8f4f-\
3e8566a43bf4"]
}, Closed]]
}, Open  ]]
}, Open  ]],

