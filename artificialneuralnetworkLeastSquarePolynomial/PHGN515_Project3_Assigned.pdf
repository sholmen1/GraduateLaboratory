   3.9338961833105927`*^9}, {3.9338962331251583`*^9, 3.933896253235195*^9}, {
   3.9338962846090612`*^9, 3.933896288276*^9}, {3.9338963196626053`*^9, 
   3.933896330607882*^9}, {3.933954740892033*^9, 3.933954768222629*^9}, {
