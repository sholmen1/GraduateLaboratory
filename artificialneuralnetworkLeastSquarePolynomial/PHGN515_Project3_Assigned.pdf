Cell[CellGroupData[{

Cell["Fitting model parameters to data: A least squares approach", "Section",
 CellChangeTimes->{{3.871835910224997*^9, 3.871835937650309*^9}, {
   3.871846584882475*^9, 3.871846586244347*^9}, {3.932937672124961*^9, 
   3.9329376988525763`*^9}, 
   3.9337110143964*^9},ExpressionUUID->"fed6452d-294b-4aff-b46d-3f9f64b9c83a"],

Cell[CellGroupData[{

Cell["Least Squares Approach: Polynomials", "Subsection",
 CellChangeTimes->{{3.931563198110231*^9, 3.931563202547127*^9}, {
  3.931563392726397*^9, 3.931563409292445*^9}, {3.932937816163011*^9, 
  3.932937825909505*^9}, {3.932992494489414*^9, 3.9329924945632067`*^9}, {
  3.9337110194134827`*^9, 
  3.933711019692665*^9}},ExpressionUUID->"05e3e521-4c55-4422-80c6-\
d2873345de05"],

Cell[TextData[{
 "Often times we model a function with a polynomial series of the form\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"n", "=", "0"}], "\[Infinity]"], " ", 
     SubscriptBox["a", "n"], 
     SuperscriptBox["x", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "bc93c3ac-6fed-4d74-a2a2-4da23b5456b9"],
 "\n\nin the specific case of a Taylor series we would have\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"n", "=", "0"}], "\[Infinity]"], " ", 
     FractionBox["1", 
      RowBox[{"n", "!"}]], 
     SubscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[PartialD]", 
          RowBox[{"(", "n", ")"}]], 
         RowBox[{"f", "(", "x", ")"}]}], 
        RowBox[{"\[PartialD]", 
         SuperscriptBox["x", 
          RowBox[{"(", "n", ")"}]]}]], ")"}], 
      RowBox[{"x", "->", 
       SubscriptBox["x", "0"]}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"x", "-", 
        SubscriptBox["x", "0"]}], ")"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"66ba2467-5718-4562-ba9b-0085859c93fb"],
 "\n\nand just to write a few terms out\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"f", "(", 
        SubscriptBox["x", "0"], ")"}], "+", 
       RowBox[{
        SubscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"\[PartialD]", 
            RowBox[{"f", "(", "x", ")"}]}], 
           RowBox[{"\[PartialD]", "x"}]], ")"}], 
         RowBox[{"x", "->", 
          SubscriptBox["x", "0"]}]], 
        RowBox[{"(", 
         RowBox[{"x", "-", 
          SubscriptBox["x", "0"]}], ")"}]}], "+", 
       RowBox[{
        FractionBox["1", "2"], 
        SubscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[PartialD]", "2"], 
            RowBox[{"f", "(", "x", ")"}]}], 
           RowBox[{"\[PartialD]", 
            SuperscriptBox["x", "2"]}]], ")"}], 
         RowBox[{"x", "->", 
          SubscriptBox["x", "0"]}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"x", "-", 
           SubscriptBox["x", "0"]}], ")"}], "2"]}], "+", 
       RowBox[{
        FractionBox["1", "6"], 
        SubscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[PartialD]", "3"], 
            RowBox[{"f", "(", "x", ")"}]}], 
           RowBox[{"\[PartialD]", 
            SuperscriptBox["x", "3"]}]], ")"}], 
         RowBox[{"x", "->", 
          SubscriptBox["x", "0"]}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"x", "-", 
           SubscriptBox["x", "0"]}], ")"}], "3"]}], "+"}], "..."}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"N", "!"}]], 
      SubscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          SuperscriptBox["\[PartialD]", 
           RowBox[{"(", "N", ")"}]], 
          RowBox[{"f", "(", "x", ")"}]}], 
         RowBox[{"\[PartialD]", 
          SuperscriptBox["x", 
           RowBox[{"(", "N", ")"}]]}]], ")"}], 
       RowBox[{"x", "->", 
        SubscriptBox["x", "0"]}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"x", "-", 
         SubscriptBox["x", "0"]}], ")"}], "N"]}]}]}], TraditionalForm]],
  ExpressionUUID->"917fbaff-c249-404e-b775-b495a3ebf3f6"],
 ".\n\nAs a comparison, the position of a particle as a function of time, \
x(t), under the influence of a constant acceleration, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "(", "t", ")"}], "=", "a"}], TraditionalForm]],
  ExpressionUUID->"5870cbc6-4421-4425-a217-570d9cedaf21"],
 ", is given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "(", "t", ")"}], "=", 
    RowBox[{
     SubscriptBox["x", "0"], "+", 
     RowBox[{
      SubscriptBox["v", "0"], "(", 
      RowBox[{"t", "-", 
       SubscriptBox["t", "0"]}], ")"}], "+", 
     RowBox[{
      FractionBox["1", "2"], "a", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"t", "-", 
         SubscriptBox["t", "0"]}], ")"}], "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"75c92926-d2ef-411f-a78c-e72d7f7d69d1"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "0"], TraditionalForm]],ExpressionUUID->
  "712052e4-1c4c-4d27-81ba-92b8697eff19"],
 " is the initial position, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "0"], TraditionalForm]],ExpressionUUID->
  "daeb02b7-9873-4342-b925-f415786ddfee"],
 " is the initial time (often taken to be zero) and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "0"], TraditionalForm]],ExpressionUUID->
  "8ea057c6-a11a-44dd-a651-442776a2fa80"],
 " is the initial speed or, in terms of derivatives on the position\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{"x", "(", 
      SubscriptBox["t", "0"], ")"}], "+", 
     RowBox[{
      SubscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"\[DifferentialD]", 
          RowBox[{"x", "(", "t", ")"}]}], 
         RowBox[{"\[DifferentialD]", "t"}]], ")"}], 
       RowBox[{"t", "->", 
        SubscriptBox["t", "0"]}]], 
      RowBox[{"(", 
       RowBox[{"t", "-", 
        SubscriptBox["t", "0"]}], ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          SuperscriptBox["\[DifferentialD]", "2"], 
          RowBox[{"x", "(", "t", ")"}]}], 
         RowBox[{"\[DifferentialD]", 
          SuperscriptBox["t", "2"]}]], ")"}], 
       RowBox[{"t", "->", 
        SubscriptBox["t", "0"]}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"t", "-", 
         SubscriptBox["t", "0"]}], ")"}], "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"b5eac6fc-ee19-4a51-bb91-fd825fbbd537"],
 "\n\nwhich is a good way to remember the Taylor series expansion. Back to \
the expression for a general polynomial expansion, writing out a few terms\n\n\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["a", "0"], "+", 
       RowBox[{
        SubscriptBox["a", "1"], "x"}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SuperscriptBox["x", "2"]}], "+", 
       RowBox[{
        SubscriptBox["a", "3"], 
        SuperscriptBox["x", "3"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "N"], 
      SuperscriptBox["x", "N"]}]}]}], TraditionalForm]],ExpressionUUID->
  "9327c62c-f749-4e76-acc3-8d79ff25062c"],
 "\n\nand now for each discrete x-value i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"{", " ", 
     RowBox[{
      SubscriptBox["x", "i"], "|", 
      RowBox[{"i", "\[Element]", "\[DoubleStruckCapitalN]"}]}], " ", "}"}]}], 
   TraditionalForm]],ExpressionUUID->"53d8e7ef-7eac-4342-94bc-e8c4005bddda"],
 "\n\n",
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{
       RowBox[{"f", 
        RowBox[{"(", 
         SubscriptBox["x", "1"], ")"}]}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", "0"], "+", 
          RowBox[{
           SubscriptBox["a", "1"], 
           SubscriptBox["x", "1"]}], "+", 
          RowBox[{
           SubscriptBox["a", "2"], 
           SubsuperscriptBox["x", "1", "2"]}], "+", 
          RowBox[{
           SubscriptBox["a", "3"], 
           SubsuperscriptBox["x", "1", "3"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "N"], 
         SubsuperscriptBox["x", "1", "N"]}]}]}]},
     {
      RowBox[{
       RowBox[{"f", 
        RowBox[{"(", 
         SubscriptBox["x", "2"], ")"}]}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", "0"], "+", 
          RowBox[{
           SubscriptBox["a", "1"], 
           SubscriptBox["x", "2"]}], "+", 
          RowBox[{
           SubscriptBox["a", "2"], 
           SubsuperscriptBox["x", "2", "2"]}], "+", 
          RowBox[{
           SubscriptBox["a", "3"], 
           SubsuperscriptBox["x", "2", "3"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "N"], 
         SubsuperscriptBox["x", "1", "N"]}]}]}]},
     {"\[VerticalEllipsis]"},
     {
      RowBox[{
       RowBox[{"f", 
        RowBox[{"(", 
         SubscriptBox["x", "M"], ")"}]}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", "0"], "+", 
          RowBox[{
           SubscriptBox["a", "1"], 
           SubscriptBox["x", "M"]}], "+", 
          RowBox[{
           SubscriptBox["a", "2"], 
           SubsuperscriptBox["x", "M", "2"]}], "+", 
          RowBox[{
           SubscriptBox["a", "3"], 
           SubsuperscriptBox["x", "M", "3"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "N"], 
         SubsuperscriptBox["x", "M", "N"]}]}]}]}
    }], TraditionalForm]],ExpressionUUID->
  "9ffe9541-47d7-4ede-91a0-9381145b8cb3"],
 "\n\nor, written using matrices\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["f", "1"]},
       {
        SubscriptBox["f", "2"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["f", "M"]}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SubsuperscriptBox["x", "1", "0"], 
         SubsuperscriptBox["x", "1", "1"], 
         SubsuperscriptBox["x", "1", "2"], "\[Ellipsis]", 
         SubsuperscriptBox["x", "1", "N"]},
        {
         SubsuperscriptBox["x", "2", "0"], 
         SubsuperscriptBox["x", "2", "1"], 
         SubsuperscriptBox["x", "2", "2"], "\[Ellipsis]", 
         SubsuperscriptBox["x", "2", "N"]},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
        {
         SubsuperscriptBox["x", "M", "0"], 
         SubsuperscriptBox["x", "M", "1"], 
         SubsuperscriptBox["x", "M", "2"], "\[Ellipsis]", 
         SubsuperscriptBox["x", "M", "N"]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["a", "1"]},
        {
         SubscriptBox["a", "2"]},
        {"\[VerticalEllipsis]"},
        {
         SubscriptBox["a", "N"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "3a704266-3f50-4605-abb3-088cf96bc1d5"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "i"], "\[Congruent]", 
    RowBox[{"f", "(", 
     SubscriptBox["x", "i"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8acae6b8-a09a-47a4-b7a0-1b2609e677c1"],
 ". Take a moment to verify this representation. In more concise, matrix \
notation\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["f", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["X", "\[LeftRightVector]"], 
     OverscriptBox["a", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"ddc5df86-adb3-4424-88a5-97ed52c00277"],
 "\n\nwe would like to solve for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "fb65e919-e854-431f-951a-1f72fed2925d"],
 " but ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "\[LeftRightVector]"], TraditionalForm]],ExpressionUUID->
  "9dc52ed6-a817-49fa-97a1-6da8e217729f"],
 " is not always square (either the system is under or over-defined). In that \
case, we just make it square by left multiplying by the transpose of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "\[LeftRightVector]"], TraditionalForm]],ExpressionUUID->
  "065ecb99-409f-4853-8165-fed1f9e34539"],
 ",\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      OverscriptBox["X", "\[LeftRightVector]"], "T"], 
     OverscriptBox["f", "\[RightVector]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["X", "\[LeftRightVector]"], "T"], 
     OverscriptBox["X", "\[LeftRightVector]"], 
     OverscriptBox["a", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"97e0484c-2c33-44c4-84b6-bf98864b0e6e"],
 "\n\nand now we can solve for ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "8e71206a-fd28-41b9-bea3-75dd64afd611"],
 " by taking the inverse of the (now) square matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["X", "\[LeftRightVector]"], "T"], 
    OverscriptBox["X", "\[LeftRightVector]"]}], TraditionalForm]],
  ExpressionUUID->"8843801e-3b02-471f-8db4-e825b04a6335"],
 ",\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["a", "\[RightVector]"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["X", "\[LeftRightVector]"], "T"], 
        OverscriptBox["X", "\[LeftRightVector]"]}], ")"}], 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      OverscriptBox["X", "\[LeftRightVector]"], "T"], 
     OverscriptBox["f", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"6bcc10d6-0a13-4180-bca6-34d68d98221c"],
 "\n\nThis is the least squares solution to fit a function. If you would like \
an in-depth derivation of the least squares method, including the reason it \
is called \[OpenCurlyQuote]least squares,\[CloseCurlyQuote] pop open the next \
section. There is also a section detailing nonlinear least squares methods, \
which we will not cover in this project."
}], "Text",
 CellChangeTimes->CompressedData["
1:eJwl0Gkog3EAx/FZc7zwygvKldu8QpolR825tpAzZ9gaS2LKSCRDWNhk7IWU
qyzPNNSsFaIoWq5IyBHebOJhL5xvzP83L7593n+DRU35EiaDwQgkwccppmg4
