   3.9339558387341137`*^9}, {3.933955903869958*^9, 3.9339560546336727`*^9}, {
   3.933956173359655*^9, 3.9339561764443607`*^9}, {3.934036554675496*^9, 
   3.934036584963285*^9}},ExpressionUUID->"a0ecd55d-bc36-4fcb-a048-\
3b38784fb65a"]
}, Open  ]]
