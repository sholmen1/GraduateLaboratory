7cc54b88acaa"],

Cell[TextData[{
 StyleBox["Notes:",
  FontWeight->"Bold"],
 "\nAll (red lines) functions in (a,c,e) will be constructed using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["f", "\[RightVector]"], "=", 
    RowBox[{
     OverscriptBox["X", "\[LeftRightVector]"], 
     OverscriptBox["a", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"05b7ce52-43fa-42ce-82eb-bcc593579a26"],
 ", ",
 StyleBox["with random coefficients",
  FontWeight->"Bold"],
 " in ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["a", "\[RightVector]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bea46e1e-50d6-43e1-a760-c5307f19d28d"],
 ". In other words, if you run your code twice, you will get two different \
results. The matrix ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "\[LeftRightVector]"], TraditionalForm]],ExpressionUUID->
  "53e90049-9897-47f6-833a-53320457c152"],
 " has elements ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", 
     RowBox[{"i", ",", "j"}]], "=", 
    SubsuperscriptBox["x", "i", 
     RowBox[{"j", "-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "a6721d08-2607-4eaa-8e86-fff5fdeecb16"],
 " (",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d005f327-e8e0-49f2-91af-d5d7df195744"],
 "  is 1 indexed here) as written in \[OpenCurlyDoubleQuote]Least Squares \
Approach: Polynomials\[CloseCurlyDoubleQuote]. You will then solve for the \
coefficients using \[OpenCurlyDoubleQuote]Least Squares Approach: Polynomials\
\[CloseCurlyDoubleQuote] i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["a", "\[RightVector]"], "LS"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["X", "\[LeftRightVector]"], "T"], 
        OverscriptBox["X", "\[LeftRightVector]"]}], ")"}], 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      OverscriptBox["X", "\[LeftRightVector]"], "T"], 
     OverscriptBox["f", "\[RightVector]"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "66066f6e-2436-4688-86d5-44527975d182"],
 ". Then reconstruct the function with the coefficients from the least \
squares solution i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["f", "\[RightVector]"], "LS"], "=", 
    RowBox[{
     OverscriptBox["X", "\[LeftRightVector]"], 
     SubscriptBox[
      OverscriptBox["a", "\[RightVector]"], "LS"]}]}], TraditionalForm]],
  ExpressionUUID->"b7d25631-feb8-4801-83dc-f82dbb8179b4"],
 "."
}], "Text",
 CellChangeTimes->{{3.933787328744812*^9, 3.933787331032897*^9}, 
   3.933787450354896*^9, {3.933847089431265*^9, 3.933847100141645*^9}, {
   3.9338471402285748`*^9, 3.9338471906279573`*^9}, {3.933856666973029*^9, 
   3.933856827184112*^9}, {3.9338569982447653`*^9, 3.9338569987683773`*^9}, {
   3.933858611750474*^9, 3.9338586372512503`*^9}, {3.933859646917585*^9, 
   3.933859725679678*^9}, {3.933859763289627*^9, 3.93385980460034*^9}, {
   3.9338601464705467`*^9, 3.933860160874807*^9}, {3.9338602365842247`*^9, 
   3.933860301912571*^9}, {3.933895911497634*^9, 3.933895923375939*^9}, {
   3.934035985725493*^9, 
   3.93403600873591*^9}},ExpressionUUID->"f7d50fe5-203a-48d7-be3d-\
c5184fcb9113"],

Cell[TextData[{
 "All plots in the left column show the function to be fitted in red, with \
the fitted model-function in blue diamonds. Plots in the same row are \
associated with the title given in the left column. For example, Plot (a) and \
(b) describe the results for an exactly determined system of equations using \
polynomials as the basis functions.\n\nPlot (a) shows the scenario where the \
system is exactly determined i.e., the same number of equations as \
coefficients (unknowns). Plot (b) shows the true coefficients in blue bars \
while the fitted coefficients are shown in the red bars along with the \
associated error in yellow. The error is the absolute value of the difference \
between the true and fitted coefficients. ",
 StyleBox["Plot (a) and Plot (b) employ a ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["6", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"8c26e3a4-a600-4986-959f-a65737f880c0"],
 StyleBox[" order polynomial to both construct the function-to-be-fitted and \
for the solution to the least squares problem.",
  FontWeight->"Bold"],
 "\n\nPlot (c) shows the scenario where the system is over determined i.e., \
more equation than coefficients. Plot (d) shows the true coefficients in blue \
bars while the fitted coefficients are shown in the red bars along with the \
associated error in yellow. The error is the absolute value of the difference \
between the true and fitted coefficients. ",
 StyleBox["Plot (c) and Plot (d) employ a ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["6", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"ea676e0a-eda8-468a-b971-0fa3aff540b7"],
 StyleBox[" order polynomial to construct the function to be fitted and an ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["8", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"87203705-d20a-42e2-8374-d7aa5f2fd22b"],
 StyleBox[" order polynomial for the solution to the least squares problem.\n\
\n",
  FontWeight->"Bold"],
 "Plot (e) shows the scenario where the system is under determined i.e., \
fewer equation than coefficients. Plot (f) shows the true coefficients in \
blue bars while the fitted coefficients are shown in the red bars along with \
the associated error in yellow. The error is the absolute value of the \
difference between the true and fitted coefficients. ",
 StyleBox["Plot (e) and Plot (f) employ a ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["8", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"90ef06e0-c4f4-43f2-933c-bbc87b48a4fe"],
 StyleBox[" order polynomial to construct the function to be fitted and an ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["6", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"9aa21b72-373c-44d6-96c3-b313ead1d85a"],
 StyleBox[" order polynomial for the solution to the least squares problem.",
  FontWeight->"Bold"],
 "\n\nPlot (g) shows the scenario where the function to be fitted is a \
non-polynomial function and given by the MatLab equation:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"cos", "(", 
           RowBox[{"2", "*", "pi", "*", "6", "*", 
            RowBox[{"x", "/", "xMax"}]}], ")"}], "."}], "*", 
         RowBox[{"exp", "(", 
          RowBox[{
           RowBox[{"-", "5"}], "*", 
           RowBox[{
            RowBox[{"abs", "(", "x", ")"}], "/", "xMax"}]}], ")"}]}], "+", 
        RowBox[{
         RowBox[{
          RowBox[{"sin", "(", 
           RowBox[{"2", "*", "pi", "*", "3", "*", 
            RowBox[{"x", "/", "xMax"}]}], ")"}], "."}], "*", 
         RowBox[{"exp", "(", 
          RowBox[{
           RowBox[{"-", "2"}], "*", 
           RowBox[{
            RowBox[{"abs", "(", "x", ")"}], "/", "xMax"}]}], ")"}]}]}], ")"}],
       "'"}]}], ";"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ed9e130e-0b99-4bb4-b1cd-fa046960940b"],
 "\n\nPlot (h) shows the error between the original function (f(x) above) and \
the reconstructed function from the polynomial fit. The error is the absolute \
value of the difference between the original and fitted function at each \
point. ",
 StyleBox["Plot (g-h) employ a ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["12", "th"], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"8991d160-524b-472c-ab03-109148b5fbdc"],
 StyleBox[" order polynomial for the solution to the least squares problem.",
  FontWeight->"Bold"],
 " Note how, even though a ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["12", "th"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fc034127-b12f-44a0-a226-b048744b16aa"],
 " order polynomial was used",
 "...this is not a good model for the given function, which is composed of \
sinusoids and strictly decaying exponentials. ",
 StyleBox["Most physical processes are well described by polynomials of order \
6 or less.",
  FontWeight->"Bold"],
 "\n\nPlot (i) also shows the scenario where the function to be fitted is a \
non-polynomial function and given by the f(x) equation above. However, in \
this case, the basis functions are complex exponentials as shown in \
\[OpenCurlyDoubleQuote]Least Squares Approach, Complex Exponentials.\
\[CloseCurlyDoubleQuote] The green line in Plot (i) is the error between the \
fit and original function multiplied by 1x",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "14"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5e36fe00-c0d1-4fd3-bea9-ce5093eb544d"],
 ", to make the error more visible. Plot (j) shows the Fourier coefficients \
from the least squares solution. ",
 StyleBox["There are as many Fourier coefficients as pixels in the original \
function. In other words, the basis matrix is square. ",
  FontWeight->"Bold"],
 "In contrast to polynomial fitting, there are often very high frequency \
components in signals we would like to fit."
}], "Text",
 CellChangeTimes->{{3.933692659348854*^9, 3.933692686882187*^9}, {
   3.933694377227049*^9, 3.933694438748076*^9}, {3.933694583024501*^9, 
   3.93369475960769*^9}, {3.933694889455358*^9, 3.933694894174077*^9}, {
   3.9336960394203777`*^9, 3.933696039614101*^9}, {3.9336960829336443`*^9, 
   3.933696240578474*^9}, {3.9336962934805*^9, 3.933696357169565*^9}, 
   3.933696387768035*^9, {3.933696419326729*^9, 3.93369645245805*^9}, {
   3.933696513306418*^9, 3.933696648388569*^9}, {3.933696697241852*^9, 
   3.933696854242498*^9}, {3.933697005293112*^9, 3.933697056962194*^9}, {
   3.933697216572061*^9, 3.933697231144107*^9}, {3.93369765480505*^9, 
   3.933697671277841*^9}, {3.933697744407199*^9, 3.9336977679061728`*^9}, {
   3.933697812195402*^9, 3.933697842053999*^9}, 3.933777952380705*^9, {
   3.9338605418622103`*^9, 3.9338605429370193`*^9}, {3.933896274275505*^9, 
   3.933896277201337*^9}, {3.9340360311470423`*^9, 
   3.934036063099481*^9}},ExpressionUUID->"ee92ebe6-3e7a-4861-a46b-\
722ebe79334f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Fitting model parameters to data: A neural network approach", \
"Subsection",
 CellChangeTimes->{{3.933697881276724*^9, 
  3.933697894224614*^9}},ExpressionUUID->"aeff0dc3-ae9e-4067-ab57-\
fd50a334347e"],

Cell[TextData[{
 StyleBox["The deliverables associated with this portion of the project are:",
  
  FontWeight->"Bold"],
 "\n1) The following plot with 10 tiles\n2) Plots must include ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "81a555dd-fb9c-40c8-99d0-7733a8af31e6"],
 " values (as in the plots below)\n3) State whether the ratio of the number \
of rows to columns is greater-than, less-than, or equal to 1 in each case\n4) \
Based on these results, which method would you use to fit a function with: \
4a) Polynomials 4b) Complex Exponentials"
}], "Text",
 CellChangeTimes->{{3.933692488028099*^9, 3.933692490750808*^9}, {
   3.933692620923024*^9, 3.9336926370583763`*^9}, {3.93369602632321*^9, 
   3.933696026970765*^9}, {3.933697550002903*^9, 3.9336975669018583`*^9}, {
   3.933777968165265*^9, 3.9337779753923693`*^9}, {3.9337787734989767`*^9, 
   3.933778803644943*^9}, {3.933787317905368*^9, 3.933787324653138*^9}, {
   3.9338603258021593`*^9, 3.933860414413539*^9}, {3.9338605141076508`*^9, 
   3.9338605160334682`*^9}, {3.933895472589736*^9, 3.933895472871688*^9}, {
   3.9338955060481253`*^9, 3.933895556708379*^9}, 
   3.933895606767992*^9},ExpressionUUID->"e6c13f73-b61e-4c00-8852-\
655fc285c7e0"],

Cell[TextData[{
 "Use the code supplied in, \
\[OpenCurlyDoubleQuote]fitFunctionANN_1D_studentVersion.m\
\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]testFitFunctionANN_1D_studentVersion.m\
\[CloseCurlyDoubleQuote] to complete this portion of the project. ",
 StyleBox["Most of the code is written for you already",
  FontWeight->"Bold"],
 ". Your job is to fill in the missing code where you find the comments:\n\n\
",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
    "%", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "=", "%"}], 
   TraditionalForm], "\n", 
  FormBox[
   RowBox[{
   "%", " ", "complete", " ", "this", " ", "block", " ", "of", " ", "code", 
    " ", "then", " ", "delete", " ", "this", " ", "comment", "                                                                                 ",
     "%"}], TraditionalForm], "\n", 
  FormBox[
   RowBox[{
    RowBox[{
    "%", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "==="}], "=", "%"}], 
   TraditionalForm]}],
